{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json",
  "title": "Meta-schema for the Static Application Security Testing (SAST) of JSON Schemas",
  "description": "If a JSON AnySchema fails validation against this meta-schema, it may be unsafe to validate untrusted data",
  "$comment": "Uses `dependencies` (draft-07) instead of `dependentSchemas`/`dependentRequired` (2019-09+) for backward compatibility.",
  "definitions": {
    "schemaArray": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#" }
    },
    "safeCount": {
      "description": "[0, Number.MAX_SAFE_INTEGER]",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "safeInteger": {
      "description": "[Number.MIN_SAFE_INTEGER, Number.MAX_SAFE_INTEGER]",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "safeNumber": {
      "description": "[-Number.MAX_VALUE, Number.MAX_VALUE], rounded down",
      "minimum": -1e308,
      "maximum": 1e308
    },
    "safePattern": {
      "$comment": "Must start with ^, end with $, exclude broad character classes (., \\S, \\W, \\D, \\C), reject empty negated character class [^] (JS any-char equivalent), reject nested quantifiers (e.g. (a+)+), and use charset ranges ie ^[\\p{L}\\p{N}\\p{P}\\p{S} \\r\\n]+$. Additional runtime ReDoS checking (e.g. safe-regex2, recheck) may be needed for full protection.",
      "allOf": [
        {
          "pattern": "^\\^(\\\\[.]|(?!\\\\[SWDC])(?!\\)[+*?{])[^.\n\r])*\\$$"
        },
        {
          "not": { "pattern": "\\[\\^\\]" }
        }
      ]
    },
    "typeArray": {
      "oneOf": [
        { "const": "array" },
        { "type": "array", "contains": { "const": "array" } }
      ]
    },
    "typeInteger": {
      "oneOf": [
        { "const": "integer" },
        {
          "type": "array",
          "contains": { "const": "integer" }
        }
      ]
    },
    "typeIntegerOrNumber": {
      "oneOf": [
        { "enum": ["integer", "number"] },
        {
          "type": "array",
          "contains": { "enum": ["integer", "number"] }
        }
      ]
    },
    "typeNumber": {
      "oneOf": [
        { "const": "number" },
        {
          "type": "array",
          "contains": { "const": "number" }
        }
      ]
    },
    "typeString": {
      "oneOf": [
        { "const": "string" },
        { "type": "array", "contains": { "const": "string" } }
      ]
    },
    "typeObject": {
      "oneOf": [
        { "const": "object" },
        { "type": "array", "contains": { "const": "object" } }
      ]
    },
    "typeOfString": {
      "properties": { "type": { "const": "string" } },
      "required": ["type"]
    },
    "typeOfInteger": {
      "properties": { "type": { "const": "integer" } },
      "required": ["type"]
    },
    "typeOfNumber": {
      "properties": { "type": { "const": "number" } },
      "required": ["type"]
    },
    "typeOfBoolean": {
      "properties": { "type": { "const": "boolean" } },
      "required": ["type"]
    },
    "typeOfNull": {
      "properties": { "type": { "const": "null" } },
      "required": ["type"]
    },
    "typeOfArray": {
      "properties": { "type": { "const": "array" } },
      "required": ["type"]
    },
    "typeOfObject": {
      "properties": { "type": { "const": "object" } },
      "required": ["type"]
    },
    "constIsString": {
      "if": { "$ref": "#/definitions/typeOfString" },
      "then": {
        "properties": {
          "const": { "type": "string" },
          "enum": { "items": { "type": "string" } }
        }
      }
    },
    "constIsInteger": {
      "if": { "$ref": "#/definitions/typeOfInteger" },
      "then": {
        "properties": {
          "const": { "type": "integer" },
          "enum": { "items": { "type": "integer" } }
        }
      }
    },
    "constIsNumber": {
      "if": { "$ref": "#/definitions/typeOfNumber" },
      "then": {
        "properties": {
          "const": { "type": "number" },
          "enum": { "items": { "type": "number" } }
        }
      }
    },
    "constIsBoolean": {
      "if": { "$ref": "#/definitions/typeOfBoolean" },
      "then": {
        "properties": {
          "const": { "type": "boolean" },
          "enum": { "items": { "type": "boolean" } }
        }
      }
    },
    "constIsNull": {
      "if": { "$ref": "#/definitions/typeOfNull" },
      "then": {
        "properties": {
          "const": { "type": "null" }
        }
      }
    },
    "constIsArray": {
      "if": { "$ref": "#/definitions/typeOfArray" },
      "then": {
        "properties": {
          "const": { "type": "array" }
        }
      }
    },
    "constIsObject": {
      "if": { "$ref": "#/definitions/typeOfObject" },
      "then": {
        "properties": {
          "const": { "type": "object" }
        }
      }
    }
  },
  "dependencies": {
    "contains": {
      "required": ["maxContains", "uniqueItems", "unevaluatedItems"]
    },
    "items": {
      "required": ["maxItems", "uniqueItems", "unevaluatedItems"]
    },
    "prefixItems": {
      "required": ["maxItems", "uniqueItems", "unevaluatedItems"]
    },
    "additionalProperties": {
      "properties": {
        "type": { "$ref": "#/definitions/typeObject" },
        "additionalProperties": {
          "oneOf": [
            {
              "const": false
            },
            {
              "type": "object",
              "required": ["type"]
            }
          ]
        }
      }
    },
    "unevaluatedProperties": {
      "properties": {
        "type": { "$ref": "#/definitions/typeObject" },
        "unevaluatedProperties": {
          "const": false
        }
      }
    },
    "unevaluatedItems": {
      "properties": {
        "type": { "$ref": "#/definitions/typeArray" },
        "unevaluatedItems": {
          "const": false
        }
      }
    },
    "maximum": {
      "oneOf": [
        {
          "properties": {
            "type": { "$ref": "#/definitions/typeInteger" },
            "maximum": { "$ref": "#/definitions/safeInteger" }
          }
        },
        {
          "properties": {
            "type": { "$ref": "#/definitions/typeNumber" },
            "maximum": { "$ref": "#/definitions/safeNumber" }
          }
        }
      ]
    },
    "exclusiveMaximum": {
      "oneOf": [
        {
          "properties": {
            "type": { "$ref": "#/definitions/typeInteger" },
            "exclusiveMaximum": { "$ref": "#/definitions/safeInteger" }
          }
        },
        {
          "properties": {
            "type": { "$ref": "#/definitions/typeNumber" },
            "exclusiveMaximum": { "$ref": "#/definitions/safeNumber" }
          }
        }
      ]
    },
    "minimum": {
      "oneOf": [
        {
          "properties": {
            "type": { "$ref": "#/definitions/typeInteger" },
            "minimum": { "$ref": "#/definitions/safeInteger" }
          }
        },
        {
          "properties": {
            "type": { "$ref": "#/definitions/typeNumber" },
            "minimum": { "$ref": "#/definitions/safeNumber" }
          }
        }
      ]
    },
    "exclusiveMinimum": {
      "oneOf": [
        {
          "properties": {
            "type": { "$ref": "#/definitions/typeInteger" },
            "exclusiveMinimum": { "$ref": "#/definitions/safeInteger" }
          }
        },
        {
          "properties": {
            "type": { "$ref": "#/definitions/typeNumber" },
            "exclusiveMinimum": {
              "$ref": "#/definitions/safeNumber"
            }
          }
        }
      ]
    },
    "minContains": {
      "properties": {
        "type": { "$ref": "#/definitions/typeArray" },
        "minContains": { "$ref": "#/definitions/safeCount" }
      }
    },
    "maxContains": {
      "properties": {
        "type": { "$ref": "#/definitions/typeArray" },
        "maxContains": { "$ref": "#/definitions/safeCount" }
      }
    },
    "minItems": {
      "properties": {
        "type": { "$ref": "#/definitions/typeArray" },
        "minItems": { "$ref": "#/definitions/safeCount" }
      }
    },
    "maxItems": {
      "properties": {
        "type": { "$ref": "#/definitions/typeArray" },
        "maxItems": { "$ref": "#/definitions/safeCount" }
      }
    },
    "minLength": {
      "properties": {
        "type": { "$ref": "#/definitions/typeString" },
        "minLength": { "$ref": "#/definitions/safeCount" }
      }
    },
    "maxLength": {
      "properties": {
        "type": { "$ref": "#/definitions/typeString" },
        "maxLength": { "$ref": "#/definitions/safeCount" }
      }
    },
    "minProperties": {
      "properties": {
        "type": { "$ref": "#/definitions/typeObject" },
        "minProperties": { "$ref": "#/definitions/safeCount" }
      }
    },
    "maxProperties": {
      "properties": {
        "type": { "$ref": "#/definitions/typeObject" },
        "maxProperties": { "$ref": "#/definitions/safeCount" }
      }
    },
    "pattern": {
      "properties": {
        "pattern": {
          "$ref": "#/definitions/safePattern"
        }
      },
      "required": ["maxLength"]
    },
    "properties": ["required", "maxProperties"],
    "patternProperties": {
      "required": ["maxProperties"],
      "properties": {
        "patternProperties": {
          "propertyNames": {
            "$ref": "#/definitions/safePattern"
          }
        }
      }
    },
    "propertyNames": {
      "properties": {
        "propertyNames": {
          "required": ["type"]
        }
      },
      "required": ["maxProperties"]
    },
    "multipleOf": {
      "required": ["type"],
      "properties": {
        "type": { "$ref": "#/definitions/typeIntegerOrNumber" },
        "multipleOf": {
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      }
    },
    "$ref": {
      "properties": {
        "$ref": {
          "type": "string",
          "maxLength": 1024,
          "pattern": "^(#|https://)"
        }
      }
    },
    "$id": {
      "properties": {
        "$id": {
          "type": "string",
          "maxLength": 1024
        }
      }
    },
    "$anchor": {
      "properties": {
        "$anchor": {
          "type": "string",
          "maxLength": 128
        }
      }
    },
    "$dynamicRef": {
      "properties": {
        "$dynamicRef": {
          "type": "string",
          "maxLength": 1024
        }
      }
    },
    "$dynamicAnchor": {
      "properties": {
        "$dynamicAnchor": {
          "type": "string",
          "maxLength": 128
        }
      }
    },
    "contentMediaType": {
      "$comment": "Media types must follow IANA registry format (RFC 6838). Source: https://www.iana.org/assignments/media-types/media-types.xhtml",
      "properties": {
        "contentMediaType": {
          "type": "string",
          "maxLength": 256,
          "pattern": "^(application|audio|font|image|message|model|multipart|text|video)/[a-zA-Z0-9][a-zA-Z0-9!#$&\\-^_.+]*$"
        }
      }
    },
    "contentEncoding": {
      "$comment": "Restrict content encoding to standard values. Source: https://json-schema.org/understanding-json-schema/reference/non_json_data#contentmediatype-and-contentencoding",
      "properties": {
        "contentEncoding": {
          "type": "string",
          "enum": [
            "quoted-printable",
            "base16",
            "base32",
            "base64"
          ]
        }
      }
    },
    "title": {
      "properties": {
        "title": { "type": "string", "maxLength": 1024 }
      }
    },
    "description": {
      "properties": {
        "description": { "type": "string", "maxLength": 4096 }
      }
    },
    "$comment": {
      "properties": {
        "$comment": { "type": "string", "maxLength": 4096 }
      }
    },
    "enum": {
      "$comment": "Ensure enum values match the declared type",
      "allOf": [
        {
          "properties": {
            "enum": {
              "$comment": "Using 2^18 for maxItems.",
              "type": "array",
              "maxItems": 262144
            }
          }
        },
        { "$ref": "#/definitions/constIsString" },
        { "$ref": "#/definitions/constIsInteger" },
        { "$ref": "#/definitions/constIsNumber" },
        { "$ref": "#/definitions/constIsBoolean" }
      ]
    },
    "format": {
      "$comment": "Formats from JSON Schema spec (https://json-schema.org/understanding-json-schema/reference/string#built-in-formats) and AJV (https://ajv.js.org/packages/ajv-formats.html)",
      "required": ["maxLength"],
      "properties": {
        "format": {
          "enum": [
            "date-time",
            "date",
            "time",
            "duration",
            "email",
            "idn-email",
            "hostname",
            "idn-hostname",
            "ipv4",
            "ipv6",
            "uri",
            "uri-reference",
            "uri-template",
            "iri",
            "iri-reference",
            "uuid",
            "json-pointer",
            "relative-json-pointer",
            "regex",
            "byte",
            "int32",
            "int64",
            "float",
            "double",
            "password",
            "binary"
          ]
        }
      }
    },
    "const": {
      "allOf": [
        { "$ref": "#/definitions/constIsString" },
        { "$ref": "#/definitions/constIsInteger" },
        { "$ref": "#/definitions/constIsNumber" },
        { "$ref": "#/definitions/constIsBoolean" },
        { "$ref": "#/definitions/constIsNull" },
        { "$ref": "#/definitions/constIsArray" },
        { "$ref": "#/definitions/constIsObject" }
      ]
    },
    "type": {
      "allOf": [
        {
          "description": "Ensure `array` has strictness.",
          "if": {
            "properties": {
              "type": {
                "$ref": "#/definitions/typeArray"
              }
            },
            "required": ["type"]
          },
          "then": {
            "oneOf": [
              { "required": ["prefixItems"] },
              {
                "required": ["items"]
              },
              {
                "required": ["contains"]
              }
            ]
          }
        },
        {
          "description": "Ensure `integer`/`number` has strictness.",
          "if": {
            "properties": {
              "type": {
                "$ref": "#/definitions/typeIntegerOrNumber"
              }
            },
            "required": ["type"]
          },
          "then": {
            "anyOf": [
              { "required": ["const"] },
              {
                "allOf": [
                  {
                    "anyOf": [
                      { "required": ["enum"] },
                      { "required": ["minimum"] },
                      { "required": ["exclusiveMinimum"] }
                    ]
                  },
                  {
                    "anyOf": [
                      { "required": ["enum"] },
                      { "required": ["maximum"] },
                      { "required": ["exclusiveMaximum"] }
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "description": "Ensure `string` has strictness.",
          "if": {
            "properties": {
              "type": {
                "$ref": "#/definitions/typeString"
              }
            },
            "required": ["type"]
          },
          "then": {
            "anyOf": [
              {
                "required": ["const"]
              },
              {
                "required": ["enum"]
              },
              {
                "required": ["pattern"]
              },
              {
                "required": ["format"]
              }
            ]
          }
        },
        {
          "description": "Ensure `object` has strictness.",
          "if": {
            "properties": {
              "type": {
                "$ref": "#/definitions/typeObject"
              }
            },
            "required": ["type"]
          },
          "then": {
            "anyOf": [
              {
                "required": ["additionalProperties"]
              },
              {
                "required": ["properties"]
              },
              {
                "required": ["patternProperties"]
              },
              {
                "required": ["propertyNames"]
              }
            ],
            "required": ["required", "unevaluatedProperties"]
          }
        }
      ]
    }
  },
  "properties": {
    "$defs": {
      "additionalProperties": { "$ref": "#" }
    },
    "additionalItems": { "$ref": "#" },
    "additionalProperties": { "$ref": "#" },
    "dependencies": {
      "additionalProperties": {
        "anyOf": [{ "type": "array" }, { "$ref": "#" }]
      }
    },
    "items": {
      "anyOf": [{ "$ref": "#" }, { "$ref": "#/definitions/schemaArray" }]
    },
    "prefixItems": { "$ref": "#/definitions/schemaArray" },
    "definitions": {
      "additionalProperties": { "$ref": "#" }
    },
    "contentSchema": { "$ref": "#" },
    "dependentSchemas": {
      "additionalProperties": { "$ref": "#" }
    },
    "patternProperties": {
      "additionalProperties": { "$ref": "#" }
    },
    "properties": {
      "additionalProperties": { "$ref": "#" }
    },
    "if": { "$ref": "#" },
    "then": { "$ref": "#" },
    "else": { "$ref": "#" },
    "allOf": { "$ref": "#/definitions/schemaArray" },
    "anyOf": { "$ref": "#/definitions/schemaArray" },
    "oneOf": { "$ref": "#/definitions/schemaArray" },
    "not": { "$ref": "#" },
    "contains": { "$ref": "#" },
    "propertyNames": { "$ref": "#" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json",
  "title": "Meta-schema for the Static Application Security Testing (SAST) of JSON Schemas",
  "description": "If a JSON AnySchema fails validation against this meta-schema, it may be unsafe to validate untrusted data",
  "$comment": "Uses `dependencies` (draft-07) instead of `dependentSchemas`/`dependentRequired` (2019-09+) for backward compatibility.",
  "definitions": {
    "safeAnchor":{
      "$comment": "https://json-schema.org/draft/2020-12/json-schema-core#section-8.2.2",
      "type": "string",
      "pattern": "^[a-zA-Z_][-a-zA-Z0-9_.]*$",
      "maxLength": 128
    },
    "safeArrayItemsLimits":{
      "type":"array",
      "minItems": 0,
      "maxItems": 1024,
      "uniqueItems": true
    },
    "safeObjectPropertiesLimits": {
      "type":"object",
      "minProperties": 0,
      "maxProperties": 1024
    },
    "safeValueSizeLimits": {
      "allOf": [
        { "if": { "type": "string" }, "then": { "$ref": "#/definitions/safeStringLengthLimits" } },
        { "if": { "type": "array" }, "then": { "$ref": "#/definitions/safeArrayItemsLimits" } },
        { "if": { "type": "object" }, "then": { "$ref": "#/definitions/safeObjectPropertiesLimits" } }
      ]
    },
    "safeStringLengthLimits":{
      "type":"string",
      "minLength":0,
      "maxLength": 4096
    },
    "safePropertyName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "safeArray": {
      "type": "array",
      "items": { "type": "string", "$ref": "#/definitions/safeStringLengthLimits" },
      "$ref": "#/definitions/safeArrayItemsLimits"
    },
    "safePropertyNameArray": {
      "type": "array",
      "items": { "type": "string", "$ref": "#/definitions/safePropertyName" },
      "$ref": "#/definitions/safeArrayItemsLimits"
    },
    "safeCount": {
      "description": "[0, Number.MAX_SAFE_INTEGER]",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "safeMultipleOf": {
      "description": "(0, Number.MAX_SAFE_INTEGER]",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "safeInteger": {
      "description": "[Number.MIN_SAFE_INTEGER, Number.MAX_SAFE_INTEGER]",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "safeNumber": {
      "description": "[-Number.MAX_VALUE, Number.MAX_VALUE], rounded down",
      "minimum": -1e308,
      "maximum": 1e308
    },
    "safePattern": {
      "$comment": "Use allowlist charset ranges ie ^[\\p{L}\\p{N}\\p{P}\\p{S} \\r\\n]+$.",
      "allOf": [
        {
          "$comment": "Max pattern length",
          "maxLength": 1024
        },
        {
          "$comment": "Must start with ^",
          "pattern": "^\\^"
        },
        {
          "$comment": "Must end with $",
          "pattern": "\\$$"
        },
        {
          "$comment": "Reject unescaped . (wildcard) outside character classes. Escaped \\. and dots inside [...] are allowed.",
          "not": { "pattern": "^(\\\\.|\\[([^\\\\\\]]|\\\\.)*\\]|[^.\\[\\\\])*\\." }
        },
        {
          "$comment": "Reject broad character class escapes: \\S (non-whitespace), \\W (non-word), \\D (non-digit), \\C (any byte), \\P (negated unicode property), \\B (non-word boundary)",
          "not": { "pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\[SWDCPB]" }
        },
        {
          "$comment": "Reject named backreference: \\k",
          "not": { "pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\k" }
        },
        {
          "$comment": "Reject backreferences: \\1 through \\9",
          "not": { "pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\[1-9]" }
        },
        {
          "$comment": "Reject null byte escape: \\0",
          "not": { "pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\0" }
        },
        {
          "$comment": "Reject null byte via hex escape: \\x00",
          "not": { "pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\x00" }
        },
        {
          "$comment": "Reject null byte via unicode escape: \\u0000 or \\u{0...}",
          "not": { "pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\u(0000|\\{0+\\})" }
        },
        {
          "$comment": "Reject control character escape: \\cA through \\cZ (matches control chars U+0001-U+001A)",
          "not": { "pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\c[A-Za-z]" }
        },
        {
          "$comment": "Reject unicode general category C (control, format, surrogate, private-use, unassigned) in short form: \\p{C}, \\p{Cc}, \\p{Cf}, \\p{Cs}, \\p{Co}, \\p{Cn}. These bypass \\0/\\x00/\\cA checks.",
          "not": { "pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\p\\{C[cfsno]?\\}" }
        },
        {
          "$comment": "Reject unicode general category C long names: \\p{Other}, \\p{Control}, \\p{Format}, \\p{Surrogate}, \\p{Private_Use}, \\p{Unassigned}",
          "not": { "pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\p\\{(Other|Control|Format|Surrogate|Private_Use|Unassigned)\\}" }
        },
        {
          "$comment": "Reject unbounded group repetition: )+ )*. Allows )? (optional), ){n} (exact), ){n,m} (bounded).",
          "not": { "pattern": "(^|[^\\\\])(\\\\\\\\)*\\)[+*]" }
        },
        {
          "$comment": "Reject unbounded group repeat {n,} (no upper bound, equivalent to )+)",
          "not": { "pattern": "(^|[^\\\\])(\\\\\\\\)*\\)\\{[0-9]+,\\}" }
        },
        {
          "$comment": "Reject positive lookahead: (?=...)",
          "not": { "pattern": "(^|[^\\\\])(\\\\\\\\)*\\(\\?=" }
        },
        {
          "$comment": "Reject positive lookbehind: (?<=...)",
          "not": { "pattern": "(^|[^\\\\])(\\\\\\\\)*\\(\\?<=" }
        },
        {
          "$comment": "Reject overlapping quantifiers: identical adjacent atoms with unbounded quantifiers cause O(n²) backtracking (e.g. [a-z]+[a-z]+, \\d+\\d+, a+a+)",
          "not": { "pattern": "(\\[[^\\]]+\\]|\\\\.|.)[+*]\\1[+*]" }
        },
        {
          "$comment": "Reject semantically overlapping quantifiers: \\d and [0-9] are identical character classes (e.g. \\d+[0-9]+, [0-9]*\\d+)",
          "not": { "pattern": "(\\\\d[+*]\\[0-9\\][+*]|\\[0-9\\][+*]\\\\d[+*])" }
        },
        {
          "$comment": "Reject semantically overlapping quantifiers: \\w ⊃ \\d (e.g. \\w+\\d+, \\d+\\w+)",
          "not": { "pattern": "(\\\\w[+*]\\\\d[+*]|\\\\d[+*]\\\\w[+*])" }
        },
        {
          "$comment": "Reject negated character classes [^...] (broad denylist matchers)",
          "not": { "pattern": "(^|[^\\\\])(\\\\\\\\)*\\[\\^" }
        },
        {
          "$comment": "Reject bare | before any group at top level (breaks anchoring). Use (?:...) for alternation.",
          "not": { "pattern": "^\\^[^()]*\\|" }
        },
        {
          "$comment": "Reject bare | after last group at top level (breaks anchoring)",
          "not": { "pattern": "\\|[^()]*\\$$" }
        },
        {
          "$comment": "If alternation | is used, all | must be inside balanced groups. Escaped chars (\\x) are treated as atoms, not group delimiters. Supports up to 3 levels of group nesting.",
          "if": { "pattern": "\\|" },
          "then": { "pattern": "^\\^(\\\\.|[^()|\\\\]|\\(([^()]|\\(([^()]|\\([^()]*\\))*\\))*\\))*\\$$" }
        }
      ]
    },
    "safeLocalRef": {
      "type": "string",
      "pattern": "^#[-a-zA-Z0-9_$/.]+$",
      "maxLength": 1024
    },
    "safeSchemaUrl": {
      "$comment": "Like safeUrl but also rejects query strings. Schema references should not need query parameters.",
      "allOf": [
        { "$ref": "#/definitions/safeUrl" },
        { "not": { "pattern": "\\?" } }
      ]
    },
    "safeUrl":{
      "$comment": "Blocks alternative IP representations (hex 0x7f000001, dotted-numeric 0177.0.0.1, decimal 2130706433) and standard private ranges. DNS-based SSRF bypasses require validator-level protection.",
      "type": "string",
      "allOf": [
        { "pattern": "^https://[-a-zA-Z0-9.]+\\.[a-z]+(/[-a-zA-Z0-9._/?&#=~+]*)?$" },
        { "not": { "pattern": "^https://(localhost|0[xX][0-9a-fA-F]|[0-9]+\\.[0-9]+\\.[0-9]|[0-9]{5,}|127\\.|10\\.|172\\.(1[6-9]|2[0-9]|3[01])\\.|192\\.168\\.|169\\.254\\.|\\[::1\\])" } },
        { "$comment": "Reject path traversal sequences", "not": { "pattern": "/\\.\\." } }
      ],
      "maxLength": 1024
    },
    "schemaArray": {
      "allOf": [
        { "$ref": "#/definitions/safeArrayItemsLimits" },
        {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#" }
        }
      ]
    },
    "typeArray": {
      "oneOf": [
        { "const": "array" },
        { "type": "array", "contains": { "const": "array" } }
      ]
    },
    "typeInteger": {
      "oneOf": [
        { "const": "integer" },
        {
          "type": "array",
          "contains": { "const": "integer" }
        }
      ]
    },
    "typeIntegerOrNumber": {
      "oneOf": [
        { "enum": ["integer", "number"] },
        {
          "type": "array",
          "contains": { "enum": ["integer", "number"] }
        }
      ]
    },
    "typeNumber": {
      "oneOf": [
        { "const": "number" },
        {
          "type": "array",
          "contains": { "const": "number" }
        }
      ]
    },
    "typeString": {
      "oneOf": [
        { "const": "string" },
        { "type": "array", "contains": { "const": "string" } }
      ]
    },
    "typeObject": {
      "oneOf": [
        { "const": "object" },
        { "type": "array", "contains": { "const": "object" } }
      ]
    },
    "typeOfString": {
      "properties": { "type": { "const": "string" } },
      "required": ["type"]
    },
    "typeOfInteger": {
      "properties": { "type": { "const": "integer" } },
      "required": ["type"]
    },
    "typeOfNumber": {
      "properties": { "type": { "const": "number" } },
      "required": ["type"]
    },
    "typeOfBoolean": {
      "properties": { "type": { "const": "boolean" } },
      "required": ["type"]
    },
    "typeOfNull": {
      "properties": { "type": { "const": "null" } },
      "required": ["type"]
    },
    "typeOfArray": {
      "properties": { "type": { "const": "array" } },
      "required": ["type"]
    },
    "typeOfObject": {
      "properties": { "type": { "const": "object" } },
      "required": ["type"]
    },
    "constIsString": {
      "if": { "$ref": "#/definitions/typeOfString" },
      "then": {
        "properties": {
          "const": { "type": "string" },
          "enum": { "items": { "type": "string" } }
        }
      }
    },
    "constIsInteger": {
      "if": { "$ref": "#/definitions/typeOfInteger" },
      "then": {
        "properties": {
          "const": { "type": "integer" },
          "enum": { "items": { "type": "integer" } }
        }
      }
    },
    "constIsNumber": {
      "if": { "$ref": "#/definitions/typeOfNumber" },
      "then": {
        "properties": {
          "const": { "type": "number" },
          "enum": { "items": { "type": "number" } }
        }
      }
    },
    "constIsBoolean": {
      "if": { "$ref": "#/definitions/typeOfBoolean" },
      "then": {
        "properties": {
          "const": { "type": "boolean" },
          "enum": { "items": { "type": "boolean" } }
        }
      }
    },
    "constIsNull": {
      "if": { "$ref": "#/definitions/typeOfNull" },
      "then": {
        "properties": {
          "const": { "type": "null" }
        }
      }
    },
    "constIsArray": {
      "if": { "$ref": "#/definitions/typeOfArray" },
      "then": {
        "properties": {
          "const": { "type": "array" }
        }
      }
    },
    "constIsObject": {
      "if": { "$ref": "#/definitions/typeOfObject" },
      "then": {
        "properties": {
          "const": { "type": "object" }
        }
      }
    },
    "constIsUnionType": {
      "$comment": "When type is an array (union type), restrict const/enum to primitive types to prevent type confusion bypasses.",
      "if": {
        "properties": { "type": { "type": "array" } },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "const": {
            "type": ["string", "number", "integer", "boolean", "null"]
          },
          "enum": {
            "items": {
              "type": ["string", "number", "integer", "boolean", "null"]
            }
          }
        }
      }
    }
  },
  "properties": {
    "$defs": {
      "additionalProperties": { "$ref": "#" }
    },
    "additionalItems": { "$ref": "#" },
    "additionalProperties": { "$ref": "#" },
    "dependencies": {
      "additionalProperties": {
        "anyOf": [
          { "$ref": "#/definitions/safePropertyNameArray" },
          { "$ref": "#" }
        ]
      }
    },
    "items": {
      "anyOf": [{ "$ref": "#" }, { "$ref": "#/definitions/schemaArray" }]
    },
    "prefixItems": { "$ref": "#/definitions/schemaArray" },
    "definitions": {
      "additionalProperties": { "$ref": "#" }
    },
    "contentSchema": { "$ref": "#" },
    "dependentSchemas": {
      "additionalProperties": { "$ref": "#" }
    },
    "patternProperties": {
      "additionalProperties": { "$ref": "#" }
    },
    "properties": {
      "additionalProperties": { "$ref": "#" }
    },
    "if": { "$ref": "#" },
    "then": { "$ref": "#" },
    "else": { "$ref": "#" },
    "allOf": { "$ref": "#/definitions/schemaArray" },
    "anyOf": { "$ref": "#/definitions/schemaArray" },
    "oneOf": { "$ref": "#/definitions/schemaArray" },
    "type": {
      "oneOf": [
        { "enum": ["string", "integer", "number", "boolean", "null", "array", "object"] },
        {
          "type": "array",
          "items": { "enum": ["string", "integer", "number", "boolean", "null", "array", "object"] },
          "minItems": 1,
          "maxItems": 7,
          "uniqueItems": true,
          "not": {
            "allOf": [
              { "contains": { "const": "integer" } },
              { "contains": { "const": "number" } }
            ]
          }
        }
      ]
    },
    "not": { "$ref": "#" },
    "contains": { "$ref": "#" },
    "propertyNames": { "$ref": "#" },
    "const": { "$ref": "#/definitions/safeValueSizeLimits" },
    "default": { "$ref": "#/definitions/safeValueSizeLimits" },
    "examples": {
      "type": "array",
      "$ref": "#/definitions/safeArrayItemsLimits",
      "items": { "$ref": "#/definitions/safeValueSizeLimits" }
    },
    "required": { "$ref": "#/definitions/safePropertyNameArray" },
    "dependentRequired": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/safePropertyNameArray" }
    }
  },
  "dependencies": {
    "contains": {
      "required": ["maxContains", "maxItems", "uniqueItems", "unevaluatedItems"],
      "properties": {
        "uniqueItems": { "const": true }
      }
    },
    "items": {
      "required": ["maxItems", "uniqueItems", "unevaluatedItems"],
      "properties": {
        "uniqueItems": { "const": true }
      }
    },
    "prefixItems": {
      "required": ["maxItems", "uniqueItems", "unevaluatedItems"],
      "properties": {
        "uniqueItems": { "const": true }
      }
    },
    "additionalProperties": {
      "required": ["maxProperties"],
      "properties": {
        "type": { "$ref": "#/definitions/typeObject" },
        "additionalProperties": {
          "oneOf": [
            {
              "const": false
            },
            {
              "type": "object",
              "required": ["type"]
            }
          ]
        }
      }
    },
    "unevaluatedProperties": {
      "properties": {
        "type": { "$ref": "#/definitions/typeObject" },
        "unevaluatedProperties": {
          "const": false
        }
      }
    },
    "unevaluatedItems": {
      "properties": {
        "type": { "$ref": "#/definitions/typeArray" },
        "unevaluatedItems": {
          "const": false
        }
      }
    },
    "maximum": {
      "oneOf": [
        {
          "properties": {
            "type": { "$ref": "#/definitions/typeInteger" },
            "maximum": { "$ref": "#/definitions/safeInteger" }
          }
        },
        {
          "properties": {
            "type": { "$ref": "#/definitions/typeNumber" },
            "maximum": { "$ref": "#/definitions/safeNumber" }
          }
        }
      ]
    },
    "exclusiveMaximum": {
      "oneOf": [
        {
          "properties": {
            "type": { "$ref": "#/definitions/typeInteger" },
            "exclusiveMaximum": { "$ref": "#/definitions/safeInteger" }
          }
        },
        {
          "properties": {
            "type": { "$ref": "#/definitions/typeNumber" },
            "exclusiveMaximum": { "$ref": "#/definitions/safeNumber" }
          }
        }
      ]
    },
    "minimum": {
      "oneOf": [
        {
          "properties": {
            "type": { "$ref": "#/definitions/typeInteger" },
            "minimum": { "$ref": "#/definitions/safeInteger" }
          }
        },
        {
          "properties": {
            "type": { "$ref": "#/definitions/typeNumber" },
            "minimum": { "$ref": "#/definitions/safeNumber" }
          }
        }
      ]
    },
    "exclusiveMinimum": {
      "oneOf": [
        {
          "properties": {
            "type": { "$ref": "#/definitions/typeInteger" },
            "exclusiveMinimum": { "$ref": "#/definitions/safeInteger" }
          }
        },
        {
          "properties": {
            "type": { "$ref": "#/definitions/typeNumber" },
            "exclusiveMinimum": {
              "$ref": "#/definitions/safeNumber"
            }
          }
        }
      ]
    },
    "minContains": {
      "properties": {
        "type": { "$ref": "#/definitions/typeArray" },
        "minContains": { "$ref": "#/definitions/safeCount" }
      }
    },
    "maxContains": {
      "properties": {
        "type": { "$ref": "#/definitions/typeArray" },
        "maxContains": { "$ref": "#/definitions/safeCount" }
      }
    },
    "minItems": {
      "properties": {
        "type": { "$ref": "#/definitions/typeArray" },
        "minItems": { "$ref": "#/definitions/safeCount" }
      }
    },
    "maxItems": {
      "properties": {
        "type": { "$ref": "#/definitions/typeArray" },
        "maxItems": { "$ref": "#/definitions/safeCount" }
      }
    },
    "minLength": {
      "properties": {
        "type": { "$ref": "#/definitions/typeString" },
        "minLength": { "$ref": "#/definitions/safeCount" }
      }
    },
    "maxLength": {
      "properties": {
        "type": { "$ref": "#/definitions/typeString" },
        "maxLength": { "$ref": "#/definitions/safeCount" }
      }
    },
    "minProperties": {
      "properties": {
        "type": { "$ref": "#/definitions/typeObject" },
        "minProperties": { "$ref": "#/definitions/safeCount" }
      }
    },
    "maxProperties": {
      "properties": {
        "type": { "$ref": "#/definitions/typeObject" },
        "maxProperties": { "$ref": "#/definitions/safeCount" }
      }
    },
    "pattern": {
      "properties": {
        "pattern": {
          "$ref": "#/definitions/safePattern"
        }
      },
      "required": ["maxLength"]
    },
    "properties": ["required", "maxProperties"],
    "patternProperties": {
      "required": ["maxProperties"],
      "properties": {
        "patternProperties": {
          "propertyNames": {
            "$ref": "#/definitions/safePattern"
          }
        }
      }
    },
    "propertyNames": {
      "properties": {
        "propertyNames": {
          "required": ["type"]
        }
      },
      "required": ["maxProperties"]
    },
    "multipleOf": {
      "required": ["type"],
      "properties": {
        "type": { "$ref": "#/definitions/typeIntegerOrNumber" },
        "multipleOf": {
          "$ref": "#/definitions/safeMultipleOf"
        }
      }
    },
    "$ref": {
      "$comment": "Only allow local (#) or HTTPS references. Remote $ref URLs can be SSRF vectors (e.g. internal IPs, metadata endpoints). Validators should independently restrict or disable remote schema loading.",
      "properties": {
        "$ref": {
          "oneOf": [
            { "$ref": "#/definitions/safeSchemaUrl" },
            { "$ref": "#/definitions/safeLocalRef" }
          ]
        }
      }
    },
    "$id": {
      "properties": {
        "$id": {
          "oneOf": [
            { "$ref": "#/definitions/safeUrl" },
            { "type": "string", "maxLength": 1024, "pattern": "^[a-zA-Z0-9_-]+$" }
          ]
        }
      }
    },
    "$anchor": {
      "properties": {
        "$anchor": {
          "$ref": "#/definitions/safeAnchor"
        }
      }
    },
    "$dynamicRef": {
      "properties": {
        "$dynamicRef": {
          "oneOf": [
            { "$ref": "#/definitions/safeSchemaUrl" },
            { "$ref": "#/definitions/safeLocalRef" }
          ]
        }
      }
    },
    "$dynamicAnchor": {
      "properties": {
        "$dynamicAnchor": {
          "$ref": "#/definitions/safeAnchor"
        }
      }
    },
    "contentMediaType": {
      "$comment": "Media types must follow IANA registry format (RFC 6838). Source: https://www.iana.org/assignments/media-types/media-types.xhtml",
      "properties": {
        "contentMediaType": {
          "type": "string",
          "maxLength": 256,
          "pattern": "^(application|audio|font|image|message|model|multipart|text|video)/[a-zA-Z0-9][a-zA-Z0-9!#$&\\-^_.+]*$"
        }
      }
    },
    "contentSchema": {
      "required": ["contentMediaType"]
    },
    "contentEncoding": {
      "$comment": "Restrict content encoding to standard values. Source: https://json-schema.org/understanding-json-schema/reference/non_json_data#contentmediatype-and-contentencoding",
      "properties": {
        "contentEncoding": {
          "type": "string",
          "enum": [
            "quoted-printable",
            "base16",
            "base32",
            "base64"
          ]
        }
      }
    },
    "title": {
      "properties": {
        "title": { "type": "string", "maxLength": 1024 }
      }
    },
    "description": {
      "properties": {
        "description": { "type": "string", "maxLength": 4096 }
      }
    },
    "$comment": {
      "properties": {
        "$comment": { "type": "string", "maxLength": 4096 }
      }
    },
    "$vocabulary": {
      "$comment": "$vocabulary can disable validation vocabularies, making type/minimum/maximum/etc. no-ops. Block it entirely.",
      "properties": {
        "$vocabulary": false
      }
    },
    "$schema": {
      "$comment": "Only allow supported JSON Schema drafts. Source: https://json-schema.org/specification-links",
      "properties": {
        "$schema": {
          "enum": [
            "https://json-schema.org/draft/2020-12/schema",
            "https://json-schema.org/draft/2019-09/schema",
            "https://json-schema.org/draft-07/schema"
          ]
        }
      }

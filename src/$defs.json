{
	"safeAnchor": {
		"$comment": "https://json-schema.org/draft/2020-12/json-schema-core#section-8.2.2",
		"type": "string",
		"pattern": "^[a-zA-Z_][-a-zA-Z0-9_.]*$",
		"maxLength": 128
	},
	"safeArrayItemsLimits": {
		"type": "array",
		"minItems": 0,
		"maxItems": 1024,
		"uniqueItems": true
	},
	"safeArrayLimits": {
		"$comment": "Like safeArrayItemsLimits but without uniqueItems — for schema arrays (allOf/anyOf/oneOf/prefixItems) where deep-equal subschemas are not an injection risk and enforcing uniqueness creates odd invariants.",
		"type": "array",
		"minItems": 0,
		"maxItems": 1024
	},
	"safeObjectPropertiesLimits": {
		"type": "object",
		"minProperties": 0,
		"maxProperties": 1024
	},
	"safeValueSizeLimits": {
		"allOf": [
			{
				"if": {
					"type": "string"
				},
				"then": {
					"$ref": "#/$defs/safeStringLengthLimits"
				}
			},
			{
				"if": {
					"type": "array"
				},
				"then": {
					"$ref": "#/$defs/safeArrayItemsLimits"
				}
			},
			{
				"if": {
					"type": "object"
				},
				"then": {
					"$ref": "#/$defs/safeObjectPropertiesLimits"
				}
			}
		]
	},
	"safeStringLengthLimits": {
		"type": "string",
		"minLength": 0,
		"maxLength": 4096
	},
	"safePropertyName": {
		"$comment": "Reject property names with prototype semantics in V8 (__proto__, constructor, prototype) to mitigate prototype pollution in downstream validators that copy keys onto plain objects.",
		"type": "string",
		"minLength": 1,
		"maxLength": 1024,
		"not": {
			"enum": ["__proto__", "constructor", "prototype"]
		}
	},
	"safePropertyNameArray": {
		"$ref": "#/$defs/safeArrayItemsLimits",
		"items": {
			"$ref": "#/$defs/safePropertyName"
		}
	},
	"safeCount": {
		"description": "[0, Number.MAX_SAFE_INTEGER]",
		"type": "integer",
		"minimum": 0,
		"maximum": 9007199254740991
	},
	"safeMultipleOf": {
		"description": "(0, Number.MAX_VALUE]",
		"type": "number",
		"exclusiveMinimum": 0,
		"maximum": 1e308
	},
	"safeInteger": {
		"description": "[Number.MIN_SAFE_INTEGER, Number.MAX_SAFE_INTEGER]",
		"type": "integer",
		"minimum": -9007199254740991,
		"maximum": 9007199254740991
	},
	"safeNumber": {
		"description": "[-Number.MAX_VALUE, Number.MAX_VALUE], rounded down",
		"type": "number",
		"minimum": -1e308,
		"maximum": 1e308
	},
	"safePattern": {
		"$comment": "Use allowlist charset ranges ie ^[\\p{L}\\p{N}\\p{P}\\p{S} \\r\\n]+$.",
		"type": "string",
		"allOf": [
			{
				"$comment": "Max pattern length",
				"maxLength": 1024
			},
			{
				"$comment": "Must start with ^",
				"pattern": "^\\^"
			},
			{
				"$comment": "Must end with $",
				"pattern": "\\$$"
			},
			{
				"$comment": "Reject unescaped . (wildcard) outside character classes. Escaped \\. and dots inside [...] are allowed.",
				"not": {
					"pattern": "^(\\\\.|\\[([^\\\\\\]]|\\\\.)*\\]|[^.\\[\\\\])*\\."
				}
			},
			{
				"$comment": "Reject broad character class escapes: \\S (non-whitespace), \\W (non-word), \\D (non-digit), \\C (any byte), \\P (negated unicode property), \\B (non-word boundary), \\v (vertical tab), \\f (form feed)",
				"not": {
					"pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\[SWDCPBvf]"
				}
			},
			{
				"$comment": "Reject named backreference: \\k",
				"not": {
					"pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\k"
				}
			},
			{
				"$comment": "Reject backreferences: \\1 through \\9",
				"not": {
					"pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\[1-9]"
				}
			},
			{
				"$comment": "Reject null byte escape: \\0",
				"not": {
					"pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\0"
				}
			},
			{
				"$comment": "Reject control characters via hex escape: \\x00-\\x1f and \\x7f (DEL). Use \\r \\n \\t for those specific chars instead.",
				"not": {
					"pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\x(0[0-9a-fA-F]|1[0-9a-fA-F]|7[fF])"
				}
			},
			{
				"$comment": "Reject control characters via unicode escape: \\u0000-\\u001f and \\u007f",
				"not": {
					"pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\u00(0[0-9a-fA-F]|1[0-9a-fA-F]|7[fF])"
				}
			},
			{
				"$comment": "Reject control characters via unicode brace escape: \\u{0}-\\u{1f} and \\u{7f}",
				"not": {
					"pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\u\\{0*(0|[1-9a-fA-F]|1[0-9a-fA-F]|7[fF])\\}"
				}
			},
			{
				"$comment": "Reject control character escape: \\cA through \\cZ (matches control chars U+0001-U+001A)",
				"not": {
					"pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\c[A-Za-z]"
				}
			},
			{
				"$comment": "Reject unicode general category C (control, format, surrogate, private-use, unassigned) in short form: \\p{C}, \\p{Cc}, \\p{Cf}, \\p{Cs}, \\p{Co}, \\p{Cn}. These bypass \\0/\\x00/\\cA checks.",
				"not": {
					"pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\p\\{C[cfsno]?\\}"
				}
			},
			{
				"$comment": "Reject unicode general category C long names: \\p{Other}, \\p{Control}, \\p{Format}, \\p{Surrogate}, \\p{Private_Use}, \\p{Unassigned}",
				"not": {
					"pattern": "(^|[^\\\\])(\\\\\\\\)*\\\\p\\{(Other|Control|Format|Surrogate|Private_Use|Unassigned)\\}"
				}
			},
			{
				"$comment": "Reject unbounded group repetition: )+ )*. Allows )? (optional), ){n} (exact), ){n,m} (bounded).",
				"not": {
					"pattern": "(^|[^\\\\])(\\\\\\\\)*\\)[+*]"
				}
			},
			{
				"$comment": "Reject unbounded group repeat {n,} (no upper bound, equivalent to )+)",
				"not": {
					"pattern": "(^|[^\\\\])(\\\\\\\\)*\\)\\{[0-9]+,\\}"
				}
			},
			{
				"$comment": "Reject positive lookahead: (?=...)",
				"not": {
					"pattern": "(^|[^\\\\])(\\\\\\\\)*\\(\\?="
				}
			},
			{
				"$comment": "Reject positive lookbehind: (?<=...)",
				"not": {
					"pattern": "(^|[^\\\\])(\\\\\\\\)*\\(\\?<="
				}
			},
			{
				"$comment": "Reject negative lookahead: (?!...)",
				"not": {
					"pattern": "(^|[^\\\\])(\\\\\\\\)*\\(\\?!"
				}
			},
			{
				"$comment": "Reject negative lookbehind: (?<!...)",
				"not": {
					"pattern": "(^|[^\\\\])(\\\\\\\\)*\\(\\?<!"
				}
			},
			{
				"$comment": "Reject overlapping quantifiers: identical adjacent atoms with unbounded quantifiers cause O(n²) backtracking (e.g. [a-z]+[a-z]+, \\d+\\d+, a+a+)",
				"not": {
					"pattern": "(\\[[^\\]]+\\]|\\\\.|.)[+*]\\1[+*]"
				}
			},
			{
				"$comment": "Reject semantically overlapping quantifiers: \\d and [0-9] are identical character classes (e.g. \\d+[0-9]+, [0-9]*\\d+)",
				"not": {
					"pattern": "(\\\\d[+*]\\[0-9\\][+*]|\\[0-9\\][+*]\\\\d[+*])"
				}
			},
			{
				"$comment": "Reject semantically overlapping quantifiers: \\w ⊃ \\d (e.g. \\w+\\d+, \\d+\\w+)",
				"not": {
					"pattern": "(\\\\w[+*]\\\\d[+*]|\\\\d[+*]\\\\w[+*])"
				}
			},
			{
				"$comment": "Reject negated character classes [^...] (broad denylist matchers)",
				"not": {
					"pattern": "(^|[^\\\\])(\\\\\\\\)*\\[\\^"
				}
			},
			{
				"$comment": "Reject top-level | after ^ anchor (breaks anchoring). Allows balanced depth-1 groups between ^ and |. Use (?:...) to wrap alternation.",
				"not": {
					"pattern": "^\\^([^()]|\\([^()]*\\))*\\|"
				}
			},
			{
				"$comment": "Reject top-level | before $ anchor (breaks anchoring). Allows balanced depth-1 groups between | and $.",
				"not": {
					"pattern": "\\|([^()]|\\([^()]*\\))*\\$$"
				}
			}
		]
	},
	"safeLocalRef": {
		"type": "string",
		"pattern": "^#[-a-zA-Z0-9_$/.]+$",
		"not": { "pattern": "\\.\\." },
		"maxLength": 1024
	},
	"safeUrn": {
		"$comment": "RFC 8141 URN. NID: 2-32 chars, alphanumeric with internal hyphens. NSS: conservative allowlist ([A-Za-z0-9._:-]+) to limit attack surface; rejects percent-encoding, r/q/f components, and reserved delimiters that could bypass downstream parsers.",
		"type": "string",
		"maxLength": 1024,
		"pattern": "^urn:[A-Za-z0-9][-A-Za-z0-9]{0,30}[A-Za-z0-9]:[A-Za-z0-9._:-]+$"
	},
	"safeSchemaUrl": {
		"$comment": "Like safeUrl but also rejects query strings. Schema references should not need query parameters.",
		"allOf": [
			{
				"$ref": "#/$defs/safeUrl"
			},
			{
				"not": {
					"pattern": "\\?"
				}
			}
		]
	},
	"safeIdUrl": {
		"$comment": "Like safeUrl but rejects fragments. JSON Schema spec section 8.2.1: $id MUST NOT contain a non-empty fragment.",
		"allOf": [
			{
				"$ref": "#/$defs/safeUrl"
			},
			{
				"not": {
					"pattern": "#"
				}
			}
		]
	},
	"safeUrl": {
		"$comment": "Blocks alternative IP representations (hex 0x7f000001, dotted-numeric 0177.0.0.1, decimal 2130706433) and standard private ranges. DNS-based SSRF bypasses require validator-level protection. Explicit ports are rejected entirely; only the implicit default HTTPS port 443 is reachable — strip `:443` before validation if your source includes it.",
		"type": "string",
		"allOf": [
			{
				"pattern": "^https://[-a-zA-Z0-9.]+\\.[a-zA-Z]+(/[-a-zA-Z0-9._/?&#=~+]*)?$"
			},
			{
				"not": {
					"pattern": "^https://(localhost|0[xX][0-9a-fA-F]|[0-9]+\\.[0-9]+\\.[0-9]|[0-9]{5,}|127\\.|10\\.|172\\.(1[6-9]|2[0-9]|3[01])\\.|192\\.168\\.|169\\.254\\.|\\[::1\\])"
				}
			},
			{
				"$comment": "Reject double-dot in hostname (invalid DNS, potential normalization bypass)",
				"not": {
					"pattern": "^https://[-a-zA-Z0-9.]*\\.\\."
				}
			},
			{
				"$comment": "Reject leading hyphen or hyphen before dot in hostname (RFC 952/1123)",
				"not": {
					"pattern": "^https://(-|[-a-zA-Z0-9.]*-\\.)"
				}
			},
			{
				"$comment": "Reject path traversal sequences",
				"not": {
					"pattern": "/\\.\\."
				}
			},
			{
				"$comment": "Reject double-slash in URL path (normalization bypass)",
				"not": {
					"pattern": "^https://[^/]+//"
				}
			}
		],
		"maxLength": 1024
	},
	"schemaArray": {
		"allOf": [
			{
				"$ref": "#/$defs/safeArrayLimits"
			},
			{
				"type": "array",
				"minItems": 1,
				"items": {
					"$ref": "#/$defs/schemaRules"
				}
			}
		]
	},
	"typeArray": {
		"oneOf": [
			{
				"const": "array"
			},
			{
				"type": "array",
				"contains": {
					"const": "array"
				}
			}
		]
	},
	"typeInteger": {
		"oneOf": [
			{
				"const": "integer"
			},
			{
				"type": "array",
				"contains": {
					"const": "integer"
				}
			}
		]
	},
	"typeIntegerOrNumber": {
		"oneOf": [
			{
				"enum": ["integer", "number"]
			},
			{
				"type": "array",
				"contains": {
					"enum": ["integer", "number"]
				}
			}
		]
	},
	"typeNumber": {
		"oneOf": [
			{
				"const": "number"
			},
			{
				"type": "array",
				"contains": {
					"const": "number"
				}
			}
		]
	},
	"typeString": {
		"oneOf": [
			{
				"const": "string"
			},
			{
				"type": "array",
				"contains": {
					"const": "string"
				}
			}
		]
	},
	"typeObject": {
		"oneOf": [
			{
				"const": "object"
			},
			{
				"type": "array",
				"contains": {
					"const": "object"
				}
			}
		]
	},
	"typeOfString": {
		"properties": {
			"type": {
				"const": "string"
			}
		},
		"required": ["type"]
	},
	"typeOfInteger": {
		"properties": {
			"type": {
				"const": "integer"
			}
		},
		"required": ["type"]
	},
	"typeOfNumber": {
		"properties": {
			"type": {
				"const": "number"
			}
		},
		"required": ["type"]
	},
	"typeOfBoolean": {
		"properties": {
			"type": {
				"const": "boolean"
			}
		},
		"required": ["type"]
	},
	"typeOfNull": {
		"properties": {
			"type": {
				"const": "null"
			}
		},
		"required": ["type"]
	},
	"typeOfArray": {
		"properties": {
			"type": {
				"const": "array"
			}
		},
		"required": ["type"]
	},
	"typeOfObject": {
		"properties": {
			"type": {
				"const": "object"
			}
		},
		"required": ["type"]
	},
	"constIsString": {
		"if": {
			"$ref": "#/$defs/typeOfString"
		},
		"then": {
			"properties": {
				"const": {
					"type": "string"
				},
				"enum": {
					"items": {
						"type": "string"
					}
				}
			}
		}
	},
	"constIsInteger": {
		"if": {
			"$ref": "#/$defs/typeOfInteger"
		},
		"then": {
			"properties": {
				"const": {
					"type": "integer"
				},
				"enum": {
					"items": {
						"type": "integer"
					}
				}
			}
		}
	},
	"constIsNumber": {
		"if": {
			"$ref": "#/$defs/typeOfNumber"
		},
		"then": {
			"properties": {
				"const": {
					"type": "number"
				},
				"enum": {
					"items": {
						"type": "number"
					}
				}
			}
		}
	},
	"constIsBoolean": {
		"if": {
			"$ref": "#/$defs/typeOfBoolean"
		},
		"then": {
			"properties": {
				"const": {
					"type": "boolean"
				},
				"enum": {
					"items": {
						"type": "boolean"
					}
				}
			}
		}
	},
	"constIsNull": {
		"if": {
			"$ref": "#/$defs/typeOfNull"
		},
		"then": {
			"properties": {
				"const": {
					"type": "null"
				},
				"enum": {
					"items": {
						"type": "null"
					}
				}
			}
		}
	},
	"constIsArray": {
		"if": {
			"$ref": "#/$defs/typeOfArray"
		},
		"then": {
			"properties": {
				"const": {
					"type": "array"
				},
				"enum": {
					"items": {
						"type": "array"
					}
				}
			}
		}
	},
	"constIsObject": {
		"if": {
			"$ref": "#/$defs/typeOfObject"
		},
		"then": {
			"properties": {
				"const": {
					"type": "object"
				},
				"enum": {
					"items": {
						"type": "object"
					}
				}
			}
		}
	},
	"constIsUnionType": {
		"$comment": "When type is an array (union type), restrict const/enum to primitive types to prevent type confusion bypasses.",
		"if": {
			"properties": {
				"type": {
					"type": "array"
				}
			},
			"required": ["type"]
		},
		"then": {
			"properties": {
				"const": {
					"type": ["string", "number", "boolean", "null"]
				},
				"enum": {
					"items": {
						"type": ["string", "number", "boolean", "null"]
					}
				}
			}
		}
	},
	"properties.$defs": {
		"$ref": "#/$defs/safeObjectPropertiesLimits",
		"propertyNames": {
			"$ref": "#/$defs/safePropertyName"
		},
		"additionalProperties": {
			"$ref": "#/$defs/schemaRules"
		}
	},
	"properties.additionalItems": {
		"$comment": "Deprecated in 2020-12. Use prefixItems + items instead.",
		"$ref": "#/$defs/schemaRules"
	},
	"properties.additionalProperties": {
		"$ref": "#/$defs/schemaRules"
	},
	"properties.items": {
		"anyOf": [
			{
				"$ref": "#/$defs/schemaRules"
			},
			{
				"$ref": "#/$defs/schemaArray"
			}
		]
	},
	"properties.definitions": {
		"$ref": "#/$defs/safeObjectPropertiesLimits",
		"propertyNames": {
			"$ref": "#/$defs/safePropertyName"
		},
		"additionalProperties": {
			"$ref": "#/$defs/schemaRules"
		}
	},
	"properties.contentSchema": {
		"$ref": "#/$defs/schemaRules"
	},
	"properties.dependentSchemas": {
		"$ref": "#/$defs/safeObjectPropertiesLimits",
		"propertyNames": {
			"$ref": "#/$defs/safePropertyName"
		},
		"additionalProperties": {
			"$ref": "#/$defs/schemaRules"
		}
	},
	"properties.patternProperties": {
		"$comment": "Prototype-pollution-prone names (__proto__, constructor, prototype) cannot be reliably denied at the meta-schema layer because patternProperties keys are regex strings — any literal denylist is trivially bypassed (^_{2}proto_{2}$, ^.{9}$, ^[a-z_]{9}$). Detection runs at the cli.js crawlSchema layer, which compiles each key and tests it against the denylisted names.",
		"$ref": "#/$defs/safeObjectPropertiesLimits",
		"additionalProperties": {
			"$ref": "#/$defs/schemaRules"
		}
	},
	"properties.properties": {
		"$ref": "#/$defs/safeObjectPropertiesLimits",
		"propertyNames": {
			"$ref": "#/$defs/safePropertyName"
		},
		"additionalProperties": {
			"$ref": "#/$defs/schemaRules"
		}
	},
	"properties.if": {
		"$ref": "#/$defs/schemaRules"
	},
	"properties.then": {
		"$ref": "#/$defs/schemaRules"
	},
	"properties.else": {
		"$ref": "#/$defs/schemaRules"
	},
	"properties.allOf": {
		"$ref": "#/$defs/schemaArray"
	},
	"properties.anyOf": {
		"$ref": "#/$defs/schemaArray"
	},
	"properties.oneOf": {
		"$ref": "#/$defs/schemaArray"
	},
	"properties.type": {
		"oneOf": [
			{
				"enum": [
					"string",
					"integer",
					"number",
					"boolean",
					"null",
					"array",
					"object"
				]
			},
			{
				"type": "array",
				"items": {
					"enum": [
						"string",
						"integer",
						"number",
						"boolean",
						"null",
						"array",
						"object"
					]
				},
				"minItems": 1,
				"maxItems": 7,
				"uniqueItems": true,
				"not": {
					"allOf": [
						{
							"contains": {
								"const": "integer"
							}
						},
						{
							"contains": {
								"const": "number"
							}
						}
					]
				}
			}
		]
	},
	"properties.not": {
		"$ref": "#/$defs/schemaRules"
	},
	"properties.contains": {
		"$ref": "#/$defs/schemaRules"
	},
	"properties.propertyNames": {
		"$ref": "#/$defs/schemaRules"
	},
	"properties.const": {
		"$ref": "#/$defs/safeValueSizeLimits"
	},
	"properties.default": {
		"$ref": "#/$defs/safeValueSizeLimits"
	},
	"properties.examples": {
		"type": "array",
		"$ref": "#/$defs/safeArrayItemsLimits",
		"items": {
			"$ref": "#/$defs/safeValueSizeLimits"
		}
	},
	"properties.required": {
		"$ref": "#/$defs/safePropertyNameArray"
	},
	"properties.dependencies": {
		"$comment": "Pre-2019-09 keyword that accepts either an array of property names (dependentRequired-equivalent) or a subschema (dependentSchemas-equivalent). Each entry is dispatched to the matching validator.",
		"$ref": "#/$defs/safeObjectPropertiesLimits",
		"additionalProperties": {
			"oneOf": [
				{
					"$ref": "#/$defs/safePropertyNameArray"
				},
				{
					"$ref": "#/$defs/schemaRules"
				}
			]
		}

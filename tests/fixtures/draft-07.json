[
  {
    "description": "draft-07 base validation",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:draft-07"
    },
    "tests": [
      {
        "description": "Should pass minimal secure draft-07 schema",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "$id": "test",
          "type": "object",
          "required": [
            "name"
          ],
          "additionalProperties": false,
          "maxProperties": 10,
          "properties": {
            "name": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            }
          }
        },
        "valid": true
      },
      {
        "description": "Should pass draft-07 schema with if/then/else",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "$id": "test",
          "type": "string",
          "enum": [
            "a",
            "b"
          ],
          "maxLength": 8,
          "if": {
            "type": "string",
            "const": "a",
            "maxLength": 8
          },
          "then": {
            "type": "string",
            "const": "a",
            "maxLength": 8
          },
          "else": {
            "type": "string",
            "const": "b",
            "maxLength": 8
          }
        },
        "valid": true
      },
      {
        "description": "Should pass when schema uses $ref alone (no type required)",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "$id": "test",
          "$ref": "#/definitions/name"
        },
        "valid": true
      },
      {
        "description": "Should fail when $schema declares 2019-09",
        "data": {
          "$schema": "https://json-schema.org/draft/2019-09/schema",
          "$id": "test",
          "type": "string",
          "maxLength": 64,
          "pattern": "^[a-z]+$"
        },
        "valid": false
      },
      {
        "description": "Should fail when schema uses $defs (2019-09+)",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "$id": "test",
          "$defs": {
            "name": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            }
          },
          "type": "string",
          "maxLength": 64,
          "pattern": "^[a-z]+$"
        },
        "valid": false
      },
      {
        "description": "Should fail when schema uses $anchor (2019-09+)",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "$id": "test",
          "$anchor": "name",
          "type": "string",
          "maxLength": 64,
          "pattern": "^[a-z]+$"
        },
        "valid": false
      },
      {
        "description": "Should fail when schema uses unevaluatedProperties (2019-09+)",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "$id": "test",
          "type": "object",
          "required": [
            "name"
          ],
          "unevaluatedProperties": false,
          "maxProperties": 10,
          "properties": {
            "name": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            }
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when schema uses prefixItems (2020-12)",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "$id": "test",
          "type": "array",
          "prefixItems": [
            {
              "type": "string",
              "maxLength": 10,
              "pattern": "^[a-z]+$"
            }
          ],
          "maxItems": 10,
          "uniqueItems": true
        },
        "valid": false
      },
      {
        "description": "Should pass when `dependencies` uses the array form (draft-07 has no dependentRequired)",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "$id": "test",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "a": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            },
            "b": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            }
          },
          "required": [],
          "maxProperties": 10,
          "dependencies": {
            "a": ["b"]
          }
        },
        "valid": true
      },
      {
        "description": "Should pass when `dependencies` uses the subschema form (draft-07 has no dependentSchemas)",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "$id": "test",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "a": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            }
          },
          "required": [],
          "maxProperties": 10,
          "dependencies": {
            "a": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "b": {
                  "type": "string",
                  "maxLength": 64,
                  "pattern": "^[a-z]+$"
                }
              },
              "required": [],
              "maxProperties": 10
            }
          }
        },
        "valid": true
      },
      {
        "description": "Should fail when `dependencies` array form contains an empty property name (safePropertyName minLength)",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "$id": "test",
          "type": "object",
          "properties": {
            "a": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            }
          },
          "required": [],
          "maxProperties": 10,
          "dependencies": {
            "a": [""]
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when `dependencies` subschema form violates schemaRules (unbounded string)",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "$id": "test",
          "type": "object",
          "properties": {
            "a": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            }
          },
          "required": [],
          "maxProperties": 10,
          "dependencies": {
            "a": {
              "type": "string"
            }
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when `deprecated` is used (not in draft-07 spec)",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "$id": "test",
          "type": "string",
          "maxLength": 8,
          "enum": ["a"],
          "deprecated": true
        },
        "valid": false
      },
      {
        "description": "Should pass when enum is set without maxLength (enum bounds value space)",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "$id": "test",
          "type": "string",
          "enum": ["a", "bb"]
        },
        "valid": true
      },
      {
        "description": "Should pass when const is set without maxLength (const bounds value space)",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "$id": "test",
          "type": "string",
          "const": "fixed"
        },
        "valid": true
      },
      {
        "description": "Should fail when pattern is set without maxLength",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^[a-z]+$"
        },
        "valid": false
      },
      {
        "description": "Should fail when format is set without maxLength",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "$id": "test",
          "type": "string",
          "format": "uuid"
        },
        "valid": false
      }
    ]
  }
]


[
  {
    "description": "allOf recursive validation",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass when allOf inner schemas are secure",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "allOf": [
            {
              "type": "string",
              "enum": [
                "a"
              ],
              "maxLength": 256
            },
            {
              "type": "string",
              "const": "a",
              "maxLength": 256
            }
          ]
        },
        "valid": true
      },
      {
        "description": "Should fail when allOf contains an insecure inner schema",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "allOf": [
            {
              "type": "string",
              "enum": [
                "a"
              ]
            },
            {
              "type": "string"
            }
          ]
        },
        "valid": false
      }
    ]
  },
  {
    "description": "anyOf recursive validation",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass when anyOf inner schemas are secure",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "a"
              ],
              "maxLength": 256
            },
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 1
            }
          ]
        },
        "valid": true
      },
      {
        "description": "Should fail when anyOf contains an insecure inner schema",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "a"
              ]
            },
            {
              "type": "string"
            }
          ]
        },
        "valid": false
      }
    ]
  },
  {
    "description": "oneOf recursive validation",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass when oneOf inner schemas are secure",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "a"
              ],
              "maxLength": 256
            },
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 1
            }
          ]
        },
        "valid": true
      },
      {
        "description": "Should fail when oneOf contains an insecure inner schema",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "a"
              ]
            },
            {
              "type": "string"
            }
          ]
        },
        "valid": false
      }
    ]
  },
  {
    "description": "not recursive validation",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass when not is used alongside type constraints",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "enum": [
            "a",
            "b"
          ],
          "maxLength": 256,
          "not": {
            "type": "string",
            "const": "b",
            "maxLength": 256
          }
        },
        "valid": true
      },
      {
        "description": "Should fail when not is used standalone (accepts nearly everything)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "not": {
            "type": "null"
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when not inner schema is insecure",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "enum": [
            "a"
          ],
          "maxLength": 256,
          "not": {
            "type": "string"
          }
        },
        "valid": false
      }
    ]
  },
  {
    "description": "if/then/else recursive validation",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass when if/then/else used alongside type (primary keyword)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "enum": [
            "a",
            "b"
          ],
          "maxLength": 256,
          "if": {
            "type": "string",
            "enum": [
              "a"
            ],
            "maxLength": 256
          },
          "then": {
            "type": "string",
            "const": "a",
            "maxLength": 256
          },
          "else": {
            "type": "string",
            "enum": [
              "b"
            ],
            "maxLength": 256
          }
        },
        "valid": true
      },
      {
        "description": "Should fail when then inner schema is insecure",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "enum": [
            "a",
            "b"
          ],
          "maxLength": 256,
          "if": {
            "type": "string",
            "enum": [
              "a"
            ],
            "maxLength": 256
          },
          "then": {
            "type": "string"
          },
          "else": {
            "type": "string",
            "enum": [
              "b"
            ],
            "maxLength": 256
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when else inner schema is insecure",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "enum": [
            "a",
            "b"
          ],
          "maxLength": 256,
          "if": {
            "type": "string",
            "enum": [
              "a"
            ],
            "maxLength": 256
          },
          "then": {
            "type": "string",
            "const": "a",
            "maxLength": 256
          },
          "else": {
            "type": "string"
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when if inner schema is insecure",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "enum": [
            "a",
            "b"
          ],
          "maxLength": 256,
          "if": {
            "type": "string"
          },
          "then": {
            "type": "string",
            "const": "a",
            "maxLength": 256
          },
          "else": {
            "type": "string",
            "enum": [
              "b"
            ],
            "maxLength": 256
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when if is used without then (no-op schema)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "if": {
            "type": "string",
            "enum": [
              "a"
            ],
            "maxLength": 256
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when if/else used without primary keyword (non-matching path unconstrained)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "if": {
            "type": "string",
            "enum": [
              "a"
            ],
            "maxLength": 256
          },
          "else": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when if/then used without primary keyword (non-matching path unconstrained)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "if": {
            "type": "null"
          },
          "then": {
            "type": "null"
          }
        },
        "valid": false
      },
      {
        "description": "Should pass when if/then used alongside type (primary provides base constraint)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "if": {
            "type": "string",
            "pattern": "^[a-z]+$",
            "maxLength": 100
          },
          "then": {
            "type": "string",
            "pattern": "^[a-z]{3,}$",
            "maxLength": 100
          },
          "maxLength": 100,
          "pattern": "^[a-z]+$"
        },
        "valid": true
      },
      {
        "description": "Should fail when then is used without if (no-op)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "then": {
            "type": "string",
            "const": "a",
            "maxLength": 256
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when else is used without if (no-op)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "else": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1
          }
        },
        "valid": false
      }
    ]
  },
  {
    "description": "boolean schema validation",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass when schema is false (rejects everything)",
        "data": false,
        "valid": true
      },
      {
        "description": "Should fail when schema is true (accepts everything)",
        "data": true,
        "valid": false
      },
      {
        "description": "Should fail when schema is a number",
        "data": 42,
        "valid": false
      },
      {
        "description": "Should fail when schema is a string",
        "data": "not-a-schema",
        "valid": false
      },
      {
        "description": "Should fail when schema is null",
        "data": null,
        "valid": false
      },
      {
        "description": "Should fail when schema is an array",
        "data": [],
        "valid": false
      },
      {
        "description": "Should fail when schema is an empty object",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test"
        },
        "valid": false
      },
      {
        "description": "Should fail when schema has only annotations",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "title": "My schema",
          "description": "Does nothing"
        },
        "valid": false
      }
    ]
  },
  {
    "description": "boolean schema in recursive positions",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should fail when if uses boolean true",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "if": true,
          "then": {
            "type": "string",
            "const": "a"
          },
          "else": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when allOf contains boolean true",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "allOf": [
            true,
            {
              "type": "string",
              "enum": [
                "a"
              ]
            }
          ]
        },
        "valid": false
      },
      {
        "description": "Should fail when properties value is boolean true",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "object",
          "properties": {
            "name": true
          },
          "unevaluatedProperties": false,
          "maxProperties": 1,
          "required": [
            "name"
          ]
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type value validation",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should fail when type is an invalid string value",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "invalid"
        },
        "valid": false
      },
      {
        "description": "Should fail when type array contains invalid values",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": [
            "string",
            "invalid"
          ],
          "maxLength": 100,
          "pattern": "^[a-z]+$"
        },
        "valid": false
      },
      {
        "description": "Should fail when type array contains non-string values",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": [
            null,
            123
          ],
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "Should fail when type array has duplicates",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": [
            "string",
            "string"
          ],
          "maxLength": 100,
          "pattern": "^[a-z]+$"
        },
        "valid": false
      },
      {
        "description": "Should pass when type is a valid single string",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "maxLength": 100,
          "pattern": "^[a-z]+$"
        },
        "valid": true
      },
      {
        "description": "Should pass when type is a valid union array",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": [
            "string",
            "null"
          ],
          "maxLength": 100,
          "enum": [
            "test"
          ]
        },
        "valid": true
      }
    ]
  },
  {
    "description": "dependentRequired array value validation",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass when dependentRequired value is a valid string array",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "object",
          "additionalProperties": false,
          "dependentRequired": {
            "a": [
              "b",
              "c"
            ]
          },
          "properties": {
            "a": {
              "type": "boolean"
            },
            "b": {
              "type": "boolean"
            },
            "c": {
              "type": "boolean"
            }
          },
          "required": [
            "a"
          ],
          "maxProperties": 10,
          "unevaluatedProperties": false
        },
        "valid": true
      },
      {
        "description": "Should fail when dependentRequired array contains non-string values",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "object",
          "dependentRequired": {
            "a": [
              123,
              null,
              true
            ]
          },
          "properties": {
            "a": {
              "type": "boolean"
            }
          },
          "required": [
            "a"
          ],
          "maxProperties": 10,
          "unevaluatedProperties": false
        },
        "valid": false
      },
      {
        "description": "Should fail when `dependencies` keyword is used (deprecated draft-07 form)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "object",
          "dependencies": {
            "a": [
              "b"
            ]
          },
          "properties": {
            "a": {
              "type": "boolean"
            },
            "b": {
              "type": "boolean"
            }
          },
          "required": [
            "a"
          ],
          "maxProperties": 10,
          "unevaluatedProperties": false
        },
        "valid": false
      },
      {
        "description": "Should fail when dependentRequired array contains empty string (invalid property name)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "object",
          "dependentRequired": {
            "a": [
              ""
            ]
          },
          "properties": {
            "a": {
              "type": "boolean"
            }
          },
          "required": [
            "a"
          ],
          "maxProperties": 10,
          "unevaluatedProperties": false
        },
        "valid": false
      }
    ]
  },
  {
    "description": "default type consistency",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass when default matches declared type (string)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^[a-z]+$",
          "maxLength": 100,
          "default": "hello"
        },
        "valid": true
      },
      {
        "description": "Should pass when default matches declared type (integer)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "default": 42
        },
        "valid": true
      },
      {
        "description": "Should pass when default matches declared type (null)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "null",
          "default": null
        },
        "valid": true
      },
      {
        "description": "Should fail when default is integer but type is string",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^[a-z]+$",
          "maxLength": 100,
          "default": 12345
        },
        "valid": false
      },
      {
        "description": "Should fail when default is string but type is integer",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "default": "not-a-number"
        },
        "valid": false
      },
      {
        "description": "Should fail when default is object but type is string",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^[a-z]+$",
          "maxLength": 100,
          "default": {
            "injected": true
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when default is array but type is boolean",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "boolean",
          "default": [
            1,
            2,
            3
          ]
        },
        "valid": false
      },
      {
        "description": "Should pass when default matches union type",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "test"
          ],
          "maxLength": 100,
          "default": null
        },
        "valid": true
      },
      {
        "description": "Should fail when default is object for union type (non-primitive)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "test"
          ],
          "maxLength": 100,
          "default": {
            "injected": true
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when default is number but union type is [string, null]",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "test"
          ],
          "maxLength": 100,
          "default": 42
        },
        "valid": false
      },
      {
        "description": "Should fail when default is boolean but union type is [string, null]",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "test"
          ],
          "maxLength": 100,
          "default": true
        },
        "valid": false
      },
      {
        "description": "Should pass when default is string and union type includes string",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "test"
          ],
          "maxLength": 100,
          "default": "test"
        },
        "valid": true
      },
      {
        "description": "Should fail when default is string but union type is [integer, null]",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": [
            "integer",
            "null"
          ],
          "enum": [
            1,
            2
          ],
          "default": "not-a-number"
        },
        "valid": false
      },
      {
        "description": "Should pass when default is integer and union type includes integer",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 100,
          "default": 42
        },
        "valid": true
      }
    ]
  },
  {
    "description": "deeply nested composition recursive validation",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass when allOf contains anyOf contains oneOf with secure schemas",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "allOf": [
            {
              "anyOf": [
                {
                  "oneOf": [
                    {
                      "type": "string",
                      "enum": [
                        "a"
                      ],
                      "maxLength": 256
                    },
                    {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 100
                    }
                  ]
                },
                {
                  "type": "boolean"
                }
              ]
            }
          ]
        },
        "valid": true
      },
      {
        "description": "Should fail when deeply nested schema is insecure",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "allOf": [
            {
              "anyOf": [

  {
    "description": "type=object rejects draft-07 `dependencies` keyword",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should fail when `dependencies` is used with a schema value (use dependentSchemas instead)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "object",
          "properties": {
            "a": {
              "type": "string",
              "enum": [
                "x"
              ],
              "maxLength": 256
            }
          },
          "dependencies": {
            "a": {
              "type": "object",
              "properties": {},
              "maxProperties": 10,
              "unevaluatedProperties": false,
              "required": []
            }
          },
          "unevaluatedProperties": false,
          "maxProperties": 10,
          "required": []
        },
        "valid": false
      },
      {
        "description": "Should fail when `dependencies` is used with an array value (use dependentRequired instead)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "object",
          "properties": {
            "a": {
              "type": "string",
              "enum": [
                "x"
              ],
              "maxLength": 256
            },
            "b": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1
            }
          },
          "dependencies": {
            "a": [
              "b"
            ]
          },
          "unevaluatedProperties": false,
          "maxProperties": 10,
          "required": []
        },
        "valid": false
      }
    ]
  },

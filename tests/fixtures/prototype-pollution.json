[
  {
    "description": "Reject __proto__ in required",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should fail when required contains __proto__",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "object",
          "unevaluatedProperties": false,
          "properties": {
            "__proto__": {
              "type": "string",
              "maxLength": 8,
              "enum": ["a"]
            }
          },
          "maxProperties": 10,
          "required": ["__proto__"]
        },
        "valid": false
      },
      {
        "description": "Should fail when required contains constructor",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "object",
          "unevaluatedProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "maxLength": 8,
              "enum": ["a"]
            }
          },
          "maxProperties": 10,
          "required": ["constructor"]
        },
        "valid": false
      },
      {
        "description": "Should fail when required contains prototype",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "object",
          "unevaluatedProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "maxLength": 8,
              "enum": ["a"]
            }
          },
          "maxProperties": 10,
          "required": ["prototype"]
        },
        "valid": false
      }
    ]
  },
  {
    "description": "Reject __proto__ in properties",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should fail when properties contains __proto__ key",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "object",
          "unevaluatedProperties": false,
          "properties": {
            "__proto__": {
              "type": "string",
              "maxLength": 8,
              "enum": ["a"]
            }
          },
          "maxProperties": 10,
          "required": ["name"]
        },
        "valid": false
      },
      {
        "description": "Should fail when properties contains constructor key",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "object",
          "unevaluatedProperties": false,
          "properties": {
            "constructor": {
              "type": "string",
              "maxLength": 8,
              "enum": ["a"]
            }
          },
          "maxProperties": 10,
          "required": ["name"]
        },
        "valid": false
      }
    ]
  },
  {
    "description": "Reject __proto__ in $defs",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should fail when $defs key is __proto__",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "object",
          "unevaluatedProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "maxLength": 8,
              "enum": ["a"]
            }
          },
          "maxProperties": 10,
          "required": ["name"],
          "$defs": {
            "__proto__": {
              "type": "string",
              "maxLength": 8,
              "enum": ["a"]
            }
          }
        },
        "valid": false
      }
    ]
  },
  {
    "description": "Reject __proto__ in dependentRequired",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should fail when dependentRequired key is __proto__",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "object",
          "unevaluatedProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "maxLength": 8,
              "enum": ["a"]
            }
          },
          "maxProperties": 10,
          "required": ["name"],
          "dependentRequired": {
            "__proto__": ["name"]
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when dependentRequired value contains __proto__",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "object",
          "unevaluatedProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "maxLength": 8,
              "enum": ["a"]
            }
          },
          "maxProperties": 10,
          "required": ["name"],
          "dependentRequired": {
            "name": ["__proto__"]
          }
        },
        "valid": false
      }
    ]
  },
  {
    "description": "Allow lookalikes (case-sensitive exact-match denylist)",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass when properties uses _proto_ (single underscores)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "object",
          "unevaluatedProperties": false,
          "properties": {
            "_proto_": {
              "type": "string",
              "maxLength": 8,
              "enum": ["a"]
            }
          },
          "maxProperties": 10,
          "required": ["_proto_"]
        },
        "valid": true
      },
      {
        "description": "Should pass when properties uses Constructor (capitalized)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "object",
          "unevaluatedProperties": false,
          "properties": {
            "Constructor": {
              "type": "string",
              "maxLength": 8,
              "enum": ["a"]
            }
          },
          "maxProperties": 10,
          "required": ["Constructor"]
        },
        "valid": true
      }
    ]
  }
]

[
  {
    "description": "draft-06 base validation",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:draft-06"
    },
    "tests": [
      {
        "description": "Should pass minimal secure draft-06 schema",
        "data": {
          "$schema": "https://json-schema.org/draft-06/schema",
          "$id": "test",
          "type": "object",
          "required": [
            "name"
          ],
          "maxProperties": 10,
          "properties": {
            "name": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            }
          }
        },
        "valid": true
      },
      {
        "description": "Should pass draft-06 schema with const",
        "data": {
          "$schema": "https://json-schema.org/draft-06/schema",
          "$id": "test",
          "type": "string",
          "const": "a",
          "maxLength": 8
        },
        "valid": true
      },
      {
        "description": "Should pass when schema uses $ref alone (no type required)",
        "data": {
          "$schema": "https://json-schema.org/draft-06/schema",
          "$id": "test",
          "$ref": "#/definitions/name"
        },
        "valid": true
      },
      {
        "description": "Should fail when $schema declares draft-07",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "$id": "test",
          "type": "string",
          "maxLength": 64,
          "pattern": "^[a-z]+$"
        },
        "valid": false
      },
      {
        "description": "Should fail when schema uses $comment (draft-07+)",
        "data": {
          "$schema": "https://json-schema.org/draft-06/schema",
          "$id": "test",
          "$comment": "note",
          "type": "string",
          "maxLength": 64,
          "pattern": "^[a-z]+$"
        },
        "valid": false
      },
      {
        "description": "Should fail when schema uses if/then/else (draft-07+)",
        "data": {
          "$schema": "https://json-schema.org/draft-06/schema",
          "$id": "test",
          "type": "string",
          "enum": [
            "a",
            "b"
          ],
          "maxLength": 8,
          "if": {
            "type": "string",
            "const": "a",
            "maxLength": 8
          },
          "then": {
            "type": "string",
            "const": "a",
            "maxLength": 8
          },
          "else": {
            "type": "string",
            "const": "b",
            "maxLength": 8
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when schema uses contentMediaType (draft-07+)",
        "data": {
          "$schema": "https://json-schema.org/draft-06/schema",
          "$id": "test",
          "type": "string",
          "maxLength": 64,
          "pattern": "^[a-z]+$",
          "contentMediaType": "text/plain"
        },
        "valid": false
      },
      {
        "description": "Should fail when schema uses $defs (2019-09+)",
        "data": {
          "$schema": "https://json-schema.org/draft-06/schema",
          "$id": "test",
          "$defs": {
            "name": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            }
          },
          "type": "string",
          "maxLength": 64,
          "pattern": "^[a-z]+$"
        },
        "valid": false
      },
      {
        "description": "Should pass when `dependencies` uses the array form (draft-06 has no dependentRequired)",
        "data": {
          "$schema": "https://json-schema.org/draft-06/schema",
          "$id": "test",
          "type": "object",
          "properties": {
            "a": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            },
            "b": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            }
          },
          "required": [],
          "maxProperties": 10,
          "dependencies": {
            "a": ["b"]
          }
        },
        "valid": true
      },
      {
        "description": "Should pass when `dependencies` uses the subschema form (draft-06 has no dependentSchemas)",
        "data": {
          "$schema": "https://json-schema.org/draft-06/schema",
          "$id": "test",
          "type": "object",
          "properties": {
            "a": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            }
          },
          "required": [],
          "maxProperties": 10,
          "dependencies": {
            "a": {
              "type": "object",
              "properties": {
                "b": {
                  "type": "string",
                  "maxLength": 64,
                  "pattern": "^[a-z]+$"
                }
              },
              "required": [],
              "maxProperties": 10
            }
          }
        },
        "valid": true
      },
      {
        "description": "Should fail when `dependencies` array form contains an empty property name (safePropertyName minLength)",
        "data": {
          "$schema": "https://json-schema.org/draft-06/schema",
          "$id": "test",
          "type": "object",
          "properties": {
            "a": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            }
          },
          "required": [],
          "maxProperties": 10,
          "dependencies": {
            "a": [""]
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when `dependencies` subschema form violates schemaRules (unbounded string)",
        "data": {
          "$schema": "https://json-schema.org/draft-06/schema",
          "$id": "test",
          "type": "object",
          "properties": {
            "a": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            }
          },
          "required": [],
          "maxProperties": 10,
          "dependencies": {
            "a": {
              "type": "string"
            }
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when `deprecated` is used (not in draft-06 spec)",
        "data": {
          "$schema": "http://json-schema.org/draft-06/schema#",
          "$id": "test",
          "type": "string",
          "maxLength": 8,
          "enum": ["a"],
          "deprecated": true
        },
        "valid": false
      }
    ]
  }
]

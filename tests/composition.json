[
  {
    "description": "allOf recursive validation",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when allOf inner schemas are secure",
        "data": {
          "allOf": [
            { "type": "string", "enum": ["a"] },
            { "type": "string", "const": "a" }
          ]
        },
        "valid": true
      },
      {
        "description": "Should fail when allOf contains an insecure inner schema",
        "data": {
          "allOf": [
            { "type": "string", "enum": ["a"] },
            { "type": "string" }
          ]
        },
        "valid": false
      }
    ]
  },
  {
    "description": "anyOf recursive validation",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when anyOf inner schemas are secure",
        "data": {
          "anyOf": [
            { "type": "string", "enum": ["a"] },
            { "type": "integer", "minimum": 0, "maximum": 1 }
          ]
        },
        "valid": true
      },
      {
        "description": "Should fail when anyOf contains an insecure inner schema",
        "data": {
          "anyOf": [
            { "type": "string", "enum": ["a"] },
            { "type": "string" }
          ]
        },
        "valid": false
      }
    ]
  },
  {
    "description": "oneOf recursive validation",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when oneOf inner schemas are secure",
        "data": {
          "oneOf": [
            { "type": "string", "enum": ["a"] },
            { "type": "integer", "minimum": 0, "maximum": 1 }
          ]
        },
        "valid": true
      },
      {
        "description": "Should fail when oneOf contains an insecure inner schema",
        "data": {
          "oneOf": [
            { "type": "string", "enum": ["a"] },
            { "type": "string" }
          ]
        },
        "valid": false
      }
    ]
  },
  {
    "description": "not recursive validation",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when not inner schema is secure",
        "data": {
          "not": { "type": "string", "enum": ["a"] }
        },
        "valid": true
      },
      {
        "description": "Should fail when not inner schema is insecure",
        "data": {
          "not": { "type": "string" }
        },
        "valid": false
      }
    ]
  },
  {
    "description": "if/then/else recursive validation",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when if/then/else inner schemas are all secure",
        "data": {
          "if": { "type": "string", "enum": ["a"] },
          "then": { "type": "string", "const": "a" },
          "else": { "type": "integer", "minimum": 0, "maximum": 1 }
        },
        "valid": true
      },
      {
        "description": "Should fail when then inner schema is insecure",
        "data": {
          "if": { "type": "string", "enum": ["a"] },
          "then": { "type": "string" },
          "else": { "type": "integer", "minimum": 0, "maximum": 1 }
        },
        "valid": false
      },
      {
        "description": "Should fail when else inner schema is insecure",
        "data": {
          "if": { "type": "string", "enum": ["a"] },
          "then": { "type": "string", "const": "a" },
          "else": { "type": "string" }
        },
        "valid": false
      },
      {
        "description": "Should fail when if inner schema is insecure",
        "data": {
          "if": { "type": "string" },
          "then": { "type": "string", "const": "a" },
          "else": { "type": "integer", "minimum": 0, "maximum": 1 }
        },
        "valid": false
      }
    ]
  },
  {
    "description": "boolean schema validation",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when schema is false (rejects everything)",
        "data": false,
        "valid": true
      },
      {
        "description": "Should fail when schema is true (accepts everything)",
        "data": true,
        "valid": false
      },
      {
        "description": "Should fail when schema is a number",
        "data": 42,
        "valid": false
      },
      {
        "description": "Should fail when schema is a string",
        "data": "not-a-schema",
        "valid": false
      },
      {
        "description": "Should fail when schema is null",
        "data": null,
        "valid": false
      },
      {
        "description": "Should fail when schema is an array",
        "data": [],
        "valid": false
      },
      {
        "description": "Should fail when schema is an empty object",
        "data": {},
        "valid": false
      },
      {
        "description": "Should fail when schema has only annotations",
        "data": {
          "title": "My schema",
          "description": "Does nothing"
        },
        "valid": false
      }
    ]
  },
  {
    "description": "boolean schema in recursive positions",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should fail when if uses boolean true",
        "data": {
          "if": true,
          "then": { "type": "string", "const": "a" },
          "else": { "type": "integer", "minimum": 0, "maximum": 1 }
        },
        "valid": false
      },
      {
        "description": "Should fail when allOf contains boolean true",
        "data": {
          "allOf": [
            true,
            { "type": "string", "enum": ["a"] }
          ]
        },
        "valid": false
      },
      {
        "description": "Should fail when properties value is boolean true",
        "data": {
          "type": "object",
          "properties": {
            "name": true
          },
          "unevaluatedProperties": false,
          "maxProperties": 1,
          "required": ["name"]
        },
        "valid": false
      }
    ]
  }
]

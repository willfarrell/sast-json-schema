  {
    "description": "title validation",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when title is within maxLength",
        "data": {
          "title": "A short title",
          "type": "null"
        },
        "valid": true
      },
      {
        "description": "Should fail when title exceeds maxLength",
        "data": {
          "title": ""
        },
        "valid": false
      }
    ]
  },
  {
    "description": "description validation",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when description is within maxLength",
        "data": {
          "description": "A short description",
          "type": "null"
        },
        "valid": true
      },
      {
        "description": "Should fail when description exceeds maxLength",
        "data": {
          "description": ""
        },
        "valid": false
      }
    ]
  },
  {
    "description": "$comment validation",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when $comment is within maxLength",
        "data": {
          "$comment": "A short comment",
          "type": "null"
        },
        "valid": true
      },
      {
        "description": "Should fail when $comment exceeds maxLength (4096)",
        "data": {
          "$comment": ""
        },
        "valid": false
      }
    ]
  },
  {
    "description": "$schema validation",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when $schema is official JSON Schema URI",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "type": "null"
        },
        "valid": true
      },
      {
        "description": "Should fail when $schema is draft-07 (unsupported)",
        "data": {
          "$schema": "https://json-schema.org/draft-07/schema",
          "type": "null"
        },
        "valid": false
      },
      {
        "description": "Should pass when $schema is draft 2019-09",
        "data": {
          "$schema": "https://json-schema.org/draft/2019-09/schema",
          "type": "null"
        },
        "valid": true
      },
      {
        "description": "Should fail when $schema is an arbitrary URL",
        "data": {
          "$schema": "https://evil.com/permissive-schema",
          "type": "null"
        },
        "valid": false
      },
      {
        "description": "Should fail when $schema uses http: scheme",
        "data": {
          "$schema": "http://json-schema.org/draft-07/schema",
          "type": "null"
        },
        "valid": false
      },
      {
        "description": "Should fail when $schema is an unsupported draft",
        "data": {
          "$schema": "https://json-schema.org/draft-06/schema",
          "type": "null"
        },
        "valid": false
      }
    ]
  },
  {
    "description": "$ref URL path traversal prevention",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should fail when $ref URL contains .. path traversal",
        "data": {
          "$ref": "https://example.com/public/../internal/schema.json"
        },
        "valid": false
      },
      {
        "description": "Should pass when $ref URL contains single dots in path segments",
        "data": {
          "$ref": "https://example.com/a.b/schema.json"
        },
        "valid": true
      },
      {
        "description": "Should fail when $ref URL contains percent-encoded path traversal (%2e%2e)",
        "data": {
          "$ref": "https://example.com/%2e%2e/%2e%2e/internal/schema.json"
        },
        "valid": false
      },
      {
        "description": "Should fail when $ref URL contains double percent-encoded traversal (%252e)",
        "data": {
          "$ref": "https://example.com/%252e%252e/internal/schema.json"
        },
        "valid": false
      },
      {
        "description": "Should fail when $ref URL contains percent-encoded characters in path",
        "data": {
          "$ref": "https://example.com/path%20with%20spaces/schema.json"
        },
        "valid": false
      }
    ]
  },
  {
    "description": "$ref URL query string restriction",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should fail when $ref URL contains query string",
        "data": {
          "$ref": "https://example.com/schema.json?version=2"
        },
        "valid": false
      },
      {
        "description": "Should fail when $ref URL contains query string with redirect",
        "data": {
          "$ref": "https://example.com/schema?redirect=http://internal"
        },
        "valid": false
      },
      {
        "description": "Should pass when $ref is local reference (no query string concern)",
        "data": {
          "$ref": "#/definitions/name"
        },
        "valid": true
      }
    ]
  },
  {
    "description": "$dynamicRef URL query string restriction",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should fail when $dynamicRef URL contains query string",
        "data": {
          "$dynamicRef": "https://example.com/schema.json?version=2",
          "type": "null"
        },
        "valid": false
      },
      {
        "description": "Should pass when $dynamicRef is local reference",
        "data": {
          "$dynamicRef": "#my-anchor",
          "type": "null"
        },
        "valid": true
      }
    ]
  },
  {
    "description": "$vocabulary validation",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should fail when $vocabulary is used to disable validation vocabulary",
        "data": {
          "$vocabulary": {
            "https://json-schema.org/draft/2020-12/vocab/validation": false
          },
          "type": "null"
        },
        "valid": false
      },
      {
        "description": "Should fail when $vocabulary is present at all",
        "data": {
          "$vocabulary": {
            "https://json-schema.org/draft/2020-12/vocab/core": true
          },
          "type": "null"
        },
        "valid": false
      }
    ]
  },
  {
    "description": "$ref URL double-dot hostname prevention",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should fail when $ref URL contains double-dot in hostname",
        "data": {
          "$ref": "https://a..b.com/schema.json"
        },
        "valid": false
      },
      {
        "description": "Should pass when $ref URL has single dots in hostname (normal domain)",
        "data": {
          "$ref": "https://schemas.example.com/schema.json"
        },
        "valid": true
      }
    ]
  },
  {
    "description": "$ref URL hostname hyphen validation",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should fail when hostname starts with a hyphen (invalid DNS)",
        "data": {
          "$ref": "https://-example.com/schema.json"
        },
        "valid": false
      },
      {
        "description": "Should fail when hostname label ends with a hyphen before dot (invalid DNS)",
        "data": {
          "$ref": "https://example-.com/schema.json"
        },
        "valid": false
      },
      {
        "description": "Should pass when hostname contains hyphens in valid positions",
        "data": {
          "$ref": "https://my-schemas.example-site.com/schema.json"
        },
        "valid": true
      }
    ]
  },
  {
    "description": "$recursiveRef validation",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when $recursiveRef is a local reference",
        "data": {
          "$recursiveRef": "#/definitions/name",
          "type": "null"
        },
        "valid": true
      },
      {
        "description": "Should pass when $recursiveRef is an https URL",
        "data": {
          "$recursiveRef": "https://example.com/schema.json",
          "type": "null"
        },
        "valid": true
      },
      {
        "description": "Should fail when $recursiveRef is a root self-reference",
        "data": {
          "$recursiveRef": "#"
        },
        "valid": false
      },
      {
        "description": "Should fail when $recursiveRef uses http: scheme",
        "data": {
          "$recursiveRef": "http://evil.com/schema",
          "type": "null"
        },
        "valid": false
      },
      {
        "description": "Should fail when $recursiveRef targets localhost (SSRF)",
        "data": {
          "$recursiveRef": "https://localhost/admin",
          "type": "null"
        },
        "valid": false
      },
      {

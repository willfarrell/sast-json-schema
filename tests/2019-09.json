[
  {
    "description": "2019-09 draft-specific keywords",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2019-09"
    },
    "tests": [
      {
        "description": "Should pass when using $recursiveAnchor: true with otherwise secure schema",
        "data": {
          "$schema": "https://json-schema.org/draft/2019-09/schema",
          "$id": "test",
          "$recursiveAnchor": true,
          "type": "object",
          "required": [
            "name"
          ],
          "unevaluatedProperties": false,
          "maxProperties": 10,
          "properties": {
            "name": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            }
          }
        },
        "valid": true
      },
      {
        "description": "Should pass when using $recursiveRef to a local fragment",
        "data": {
          "$schema": "https://json-schema.org/draft/2019-09/schema",
          "$id": "test",
          "$recursiveRef": "#/$defs/name",
          "type": "string",
          "maxLength": 64,
          "pattern": "^[a-z]+$"
        },
        "valid": true
      },
      {
        "description": "Should fail when using $dynamicRef (2020-12 only)",
        "data": {
          "$schema": "https://json-schema.org/draft/2019-09/schema",
          "$id": "test",
          "$dynamicRef": "#foo",
          "type": "string",
          "maxLength": 64,
          "pattern": "^[a-z]+$"
        },
        "valid": false
      },
      {
        "description": "Should fail when using $dynamicAnchor (2020-12 only)",
        "data": {
          "$schema": "https://json-schema.org/draft/2019-09/schema",
          "$id": "test",
          "$dynamicAnchor": "foo",
          "type": "string",
          "maxLength": 64,
          "pattern": "^[a-z]+$"
        },
        "valid": false
      },
      {
        "description": "Should fail when using prefixItems (2020-12 only)",
        "data": {
          "$schema": "https://json-schema.org/draft/2019-09/schema",
          "$id": "test",
          "type": "array",
          "prefixItems": [
            {
              "type": "string",
              "maxLength": 10,
              "pattern": "^[a-z]+$"
            }
          ],
          "maxItems": 10,
          "uniqueItems": true,
          "unevaluatedItems": false
        },
        "valid": false
      },
      {
        "description": "Should fail when $schema declares 2020-12",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "maxLength": 64,
          "pattern": "^[a-z]+$"
        },
        "valid": false
      }
    ]
  }
]

      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when multipleOf is positive",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "multipleOf": 0.5
        },
        "valid": true
      },
      {
        "description": "Should fail when multipleOf is zero",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "multipleOf": 0
        },
        "valid": false
      },
      {
        "description": "Should fail when multipleOf is negative",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "multipleOf": -1
        },
        "valid": false
      }
    ]
  },

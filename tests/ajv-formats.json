[
  {
    "description": "ajv-formats regex patterns tested against safePattern",
    "$comment": "Source: https://github.com/ajv-validator/ajv-formats/blob/master/src/formats.ts. Tests whether ajv-formats internal patterns would pass safePattern if used as a pattern keyword value. Many fail because safePattern is intentionally stricter than general regex — it blocks unescaped dots, negated classes, lookaheads, and unbounded group repeats (+/*).",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "date (fast) - pass",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^\\d\\d\\d\\d-[0-1]\\d-[0-3]\\d$",
          "maxLength": 10
        },
        "valid": true
      },
      {
        "description": "date (full) - pass",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^(\\d\\d\\d\\d)-(\\d\\d)-(\\d\\d)$",
          "maxLength": 10
        },
        "valid": true
      },
      {
        "description": "time (fast) - pass (alternation inside groups, anchoring preserved)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^(?:[0-2]\\d:[0-5]\\d:[0-5]\\d|23:59:60)(?:\\.\\d+)?(?:z|[+-]\\d\\d(?::?\\d\\d)?)$",
          "maxLength": 35
        },
        "valid": true
      },
      {
        "description": "date-time (fast) - pass (alternation inside groups, anchoring preserved)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^\\d\\d\\d\\d-[0-1]\\d-[0-3]\\dt(?:[0-2]\\d:[0-5]\\d:[0-5]\\d|23:59:60)(?:\\.\\d+)?(?:z|[+-]\\d\\d(?::?\\d\\d)?)$",
          "maxLength": 35
        },
        "valid": true
      },
      {
        "description": "iso-time (fast) - pass (alternation inside groups, anchoring preserved)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^(?:[0-2]\\d:[0-5]\\d:[0-5]\\d|23:59:60)(?:\\.\\d+)?(?:z|[+-]\\d\\d(?::?\\d\\d)?)?$",
          "maxLength": 35
        },
        "valid": true
      },
      {
        "description": "iso-date-time (fast) - pass (alternation inside groups, anchoring preserved)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^\\d\\d\\d\\d-[0-1]\\d-[0-3]\\d[t\\s](?:[0-2]\\d:[0-5]\\d:[0-5]\\d|23:59:60)(?:\\.\\d+)?(?:z|[+-]\\d\\d(?::?\\d\\d)?)?$",
          "maxLength": 35
        },
        "valid": true
      },
      {
        "description": "duration - fail (positive lookahead (?=))",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^P(?!$)((\\d+Y)?(\\d+M)?(\\d+D)?(T(?=\\d)(\\d+H)?(\\d+M)?(\\d+S)?)?|(\\d+W)?)$",
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "uri (fast) - fail (negated class [^\\s])",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^(?:[a-z][a-z0-9+\\-.]*:)(?:\\/?\\/?)[^\\s]*$",
          "maxLength": 2048
        },
        "valid": false
      },
      {
        "description": "uri-reference (fast) - fail (negated class [^\\\\])",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^(?:(?:[a-z][a-z0-9+\\-.]*:)?\\/?\\/?)?(?:[^\\\\\\s#][^\\s#]*)?(?:#[^\\\\\\s]*)?$",
          "maxLength": 2048
        },
        "valid": false
      },
      {
        "description": "email (fast) - fail (unbounded group repeat )* in domain part)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^[a-z0-9.!#$%&'*+/=?^_`{|}~-]+@[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)*$",
          "maxLength": 254
        },
        "valid": false
      },
      {
        "description": "email (full) - fail (unbounded group repeat )*)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^[a-z0-9!#$%&'*+/=?^_`{|}~-]+(?:\\.[a-z0-9!#$%&'*+/=?^_`{|}~-]+)*@(?:[a-z0-9](?:[a-z0-9-]*[a-z0-9])?\\.)+[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$",
          "maxLength": 254
        },
        "valid": false
      },
      {
        "description": "hostname - fail (positive lookahead (?=) and unescaped .)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^(?=.{1,253}\\.?$)[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[-0-9a-z]{0,61}[0-9a-z])?)* \\.?$",
          "maxLength": 253
        },
        "valid": false
      },
      {
        "description": "ipv4 - pass (alternation inside groups, bounded repeat {3})",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^(?:(?:25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)\\.){3}(?:25[0-5]|2[0-4]\\d|1\\d\\d|[1-9]?\\d)$",
          "maxLength": 15
        },
        "valid": true
      },
      {
        "description": "uuid - pass (optional group and fixed repeat allowed, no alternation)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^(?:urn:uuid:)?[0-9a-f]{8}-(?:[0-9a-f]{4}-){3}[0-9a-f]{12}$",
          "maxLength": 45
        },
        "valid": true
      },
      {
        "description": "json-pointer - fail (negated class [^~/])",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^(?:\\/(?:[^~/]|~0|~1)*)*$",
          "maxLength": 1024
        },
        "valid": false
      },
      {
        "description": "relative-json-pointer - fail (negated class [^~/])",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^(?:0|[1-9][0-9]*)(?:#|(?:\\/(?:[^~/]|~0|~1)*)*)$",
          "maxLength": 1024
        },
        "valid": false
      },
      {
        "description": "byte (base64) - fail (unbounded group repeat )*)",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "string",
          "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$",
          "maxLength": 4096
        },
        "valid": false
      }
    ]
  }
]

{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/example.json",
	"$defs": {
		"allowed": { "type": "integer", "minimum": 0, "maximum": 1 }
	},
	"type": "object",
	"unevaluatedProperties": false,
	"additionalProperties": false,
	"properties": {
		"allowed": { "$ref": "#/$defs/allowed" },
		"if": { "$ref": "#/$defs/allowed" },
		"then": { "$ref": "#/$defs/allowed" },
		"else": { "$ref": "#/$defs/allowed" }
	},
	"maxProperties": 4,
	"required": [],
	"if": {
		"type": "object",
		"unevaluatedProperties": false,
		"additionalProperties": false,
		"properties": {
			"allowed": { "$ref": "#/$defs/allowed" },
			"if": { "type": "integer", "enum": [1] },
			"then": { "$ref": "#/$defs/allowed" },
			"else": { "$ref": "#/$defs/allowed" }
		},
		"maxProperties": 4,
		"required": ["if"]
	},
	"then": {
		"type": "object",
		"unevaluatedProperties": false,
		"additionalProperties": false,
		"properties": {
			"allowed": { "$ref": "#/$defs/allowed" },
			"if": { "$ref": "#/$defs/allowed" },
			"then": { "type": "integer", "enum": [1] },
			"else": { "type": "integer", "enum": [0] }
		},
		"maxProperties": 4,
		"required": ["then", "else"]
	},
	"else": {
		"type": "object",
		"unevaluatedProperties": false,
		"additionalProperties": false,
		"properties": {
			"allowed": { "$ref": "#/$defs/allowed" },
			"if": { "$ref": "#/$defs/allowed" },
			"then": { "type": "integer", "enum": [0] },
			"else": { "type": "integer", "enum": [1] }
		},
		"maxProperties": 4,
		"required": ["then", "else"]
	}
}

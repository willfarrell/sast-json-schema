[
  {
    "description": "draft-06 base validation",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/draft-06.json"
    },
    "tests": [
      {
        "description": "Should pass minimal secure draft-06 schema",
        "data": {
          "$schema": "http://json-schema.org/draft-06/schema#",
          "$id": "test",
          "type": "object",
          "required": [
            "name"
          ],
          "maxProperties": 10,
          "properties": {
            "name": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            }
          }
        },
        "valid": true
      },
      {
        "description": "Should pass draft-06 schema with const",
        "data": {
          "$schema": "http://json-schema.org/draft-06/schema#",
          "$id": "test",
          "type": "string",
          "const": "a",
          "maxLength": 8
        },
        "valid": true
      },
      {
        "description": "Should fail when $schema declares draft-07",
        "data": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "$id": "test",
          "type": "string",
          "maxLength": 64,
          "pattern": "^[a-z]+$"
        },
        "valid": false
      },
      {
        "description": "Should fail when schema uses $comment (draft-07+)",
        "data": {
          "$schema": "http://json-schema.org/draft-06/schema#",
          "$id": "test",
          "$comment": "note",
          "type": "string",
          "maxLength": 64,
          "pattern": "^[a-z]+$"
        },
        "valid": false
      },
      {
        "description": "Should fail when schema uses if/then/else (draft-07+)",
        "data": {
          "$schema": "http://json-schema.org/draft-06/schema#",
          "$id": "test",
          "type": "string",
          "enum": [
            "a",
            "b"
          ],
          "maxLength": 8,
          "if": {
            "type": "string",
            "const": "a",
            "maxLength": 8
          },
          "then": {
            "type": "string",
            "const": "a",
            "maxLength": 8
          },
          "else": {
            "type": "string",
            "const": "b",
            "maxLength": 8
          }
        },
        "valid": false
      },
      {
        "description": "Should fail when schema uses contentMediaType (draft-07+)",
        "data": {
          "$schema": "http://json-schema.org/draft-06/schema#",
          "$id": "test",
          "type": "string",
          "maxLength": 64,
          "pattern": "^[a-z]+$",
          "contentMediaType": "text/plain"
        },
        "valid": false
      },
      {
        "description": "Should fail when schema uses $defs (2019-09+)",
        "data": {
          "$schema": "http://json-schema.org/draft-06/schema#",
          "$id": "test",
          "$defs": {
            "name": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z]+$"
            }
          },
          "type": "string",
          "maxLength": 64,
          "pattern": "^[a-z]+$"
        },
        "valid": false
      }
    ]
  }
]

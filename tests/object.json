  {
    "description": "type=object with contentSchema recursive validation",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when contentSchema is a secure schema",
        "data": {
          "type": "string",
          "contentSchema": {
            "type": "object",
            "properties": {},
            "maxProperties": 10,

  {
    "description": "type=object with dependencies schema form recursive validation",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when dependency value is a secure schema",
        "data": {
          "type": "object",
          "properties": {
            "a": {
              "type": "string",
              "enum": [
                "x"
              ],
              "maxLength": 256
            }
          },
          "dependencies": {
            "a": {
              "type": "object",
              "properties": {},
              "maxProperties": 10,
              "unevaluatedProperties": false,
              "required": []
            }
          },
          "unevaluatedProperties": false,
          "maxProperties": 10,
          "required": []
        },
        "valid": true
      },
      {
        "description": "Should pass when dependency value is an array (not recursively validated)",
        "data": {
          "type": "object",
          "properties": {
            "a": {
              "type": "string",
              "enum": [
                "x"
              ],
              "maxLength": 256
            },
            "b": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1
            }
          },
          "dependencies": {
            "a": [
              "b"
            ]
          },
          "unevaluatedProperties": false,
          "maxProperties": 10,
          "required": []
        },
        "valid": true
      },
      {
        "description": "Should fail when dependency value is an insecure schema (missing constraints)",
        "data": {
          "type": "object",
          "properties": {
            "a": {
              "type": "string",
              "enum": [
                "x"
              ]
            }
          },
          "dependencies": {
            "a": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false,
          "required": []
        },
        "valid": false
      }
    ]
  },

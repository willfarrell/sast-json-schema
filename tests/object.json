          "type": "object",
          "unevaluatedProperties": false,
          "patternProperties": {
            "^[\\p{L}]+$": {
              "type": "string"
            }
          },
          "maxProperties": 1,
          "required": []
        },
        "valid": false
      }
    ]
  },
  {

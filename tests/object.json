  {
    "description": "type=object with properties recursive validation",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when properties inner schemas are secure",
        "data": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "enum": [
                "a",
                "b"
              ],
              "maxLength": 256
            }
          },
          "unevaluatedProperties": false,
          "maxProperties": 10,
          "required": [
            "name"
          ]
        },
        "valid": true
      },
      {
        "description": "Should fail when properties inner schema is insecure (missing constraints)",
        "data": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            }
          },
          "unevaluatedProperties": false,
          "required": [
            "name"
          ]
        },
        "valid": false
      }
    ]
  },
  {

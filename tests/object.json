  {
    "description": "type=object with required",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when required is set",
        "data": {
          "type": "object",
          "unevaluatedProperties": false,
          "properties": {},
          "maxProperties": 10,
          "required": []
        },
        "valid": true
      },
      {
        "description": "Should fail when required is not set",
        "data": {
          "type": "object",
          "unevaluatedProperties": false,
          "properties": {}
        },
        "valid": false
      },
      {
        "description": "Should fail when required item exceeds maxLength (4096)",
        "data": {
          "type": "object",
          "unevaluatedProperties": false,
          "properties": {},
          "maxProperties": 10,
          "required": [
            ""
          ]
        },
        "valid": false
      },
      {
        "description": "Should pass when required items are within limits",
        "data": {
          "type": "object",
          "unevaluatedProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "enum": [
                "a"
              ],
              "maxLength": 256
            }
          },
          "maxProperties": 10,
          "required": [
            "name"
          ]
        },
        "valid": true
      }
    ]
  },
  {
    "description": "type=object with patternProperties",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when patternProperties is set",
        "data": {
          "type": "object",
          "unevaluatedProperties": false,
          "patternProperties": {
            "^00000000-0000-0000-0000-000000000000$": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1
            }
          },
          "maxProperties": 1,
          "required": []
        },
        "valid": true
      },
      {
        "description": "Should fail when patternProperties is not set",
        "data": {
          "type": "object",
          "unevaluatedProperties": false,
          "maxProperties": 1,
          "required": []
        },
        "valid": false
      },
      {
        "description": "Should fail when patternProperties key is missing leading ^",
        "data": {
          "type": "object",
          "unevaluatedProperties": false,
          "patternProperties": {
            "00000000-0000-0000-0000-000000000000$": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1
            }
          },
          "maxProperties": 1,
          "required": []
        },
        "valid": false
      },
      {
        "description": "Should fail when patternProperties key is missing trailing $",
        "data": {
          "type": "object",
          "unevaluatedProperties": false,
          "patternProperties": {
            "^00000000-0000-0000-0000-000000000000": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1
            }
          },
          "maxProperties": 1,
          "required": []
        },
        "valid": false
      },
      {
        "description": "Should fail when patternProperties key uses empty negated character class [^]",
        "data": {
          "type": "object",
          "unevaluatedProperties": false,
          "patternProperties": {
            "^[^]+$": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1
            }
          },
          "maxProperties": 1,
          "required": []
        },
        "valid": false
      }
    ]
  },
  {

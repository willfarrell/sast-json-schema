          "maxProperties": 10,
          "minProperties": 1,
          "required": []
        },
        "valid": true
      },
      {
        "description": "Should fail when minProperties is below 0",
        "data": {
          "type": "object",
          "properties": {
            "a": {
              "type": "string",
              "enum": [
                "x"
              ]
            }
          },
          "unevaluatedProperties": false,
          "minProperties": -1,
          "required": []
        },
        "valid": false
      }
    ]
  }

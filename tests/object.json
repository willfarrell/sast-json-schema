[
  {
    "description": "type=[object,null]",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass",
        "data": {
          "type": [
            "object",
            "null"
          ],
          "unevaluatedProperties": false,
          "properties": {},
          "maxProperties": 10,
          "required": []
        },
        "valid": true
      },
      {
        "description": "Should fail",
        "data": {
          "type": [
            "object",
            "null"
          ]
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=object with additionalProperties",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when additionalProperties is set",
        "data": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1
          },
          "maxProperties": 10,
          "unevaluatedProperties": false,
          "required": []
        },
        "valid": true
      },
      {
        "description": "Should pass when additionalProperties is set to false",
        "data": {
          "type": "object",
          "additionalProperties": false,
          "maxProperties": 0,
          "unevaluatedProperties": false,
          "required": []
        },
        "valid": true
      },
      {
        "description": "Should fail when additionalProperties is set to true",
        "data": {
          "type": "object",
          "additionalProperties": true,
          "unevaluatedProperties": false,
          "required": []
        },
        "valid": false
      },
      {
        "description": "Should fail when additionalProperties is not set",
        "data": {
          "type": "object",
          "unevaluatedProperties": false,
          "required": []
        },
        "valid": false
      },
      {
        "description": "Should fail when additionalProperties is set without maxProperties",
        "data": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1
          },
          "unevaluatedProperties": false,
          "required": []
        },
        "valid": false
      }
    ]
  },

[
  {
    "description": "type=[integer,null]",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": [
            "integer",
            "null"
          ],
          "enum": [
            -9007199254740991,
            9007199254740991
          ]
        },
        "valid": true
      },
      {
        "description": "Should fail",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": [
            "integer",
            "null"
          ]
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=integer with const",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass when const is set",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "const": 42
        },
        "valid": true
      },
      {
        "description": "Should fail when const type does not match declared type",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "const": "not-a-number"
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=integer with enum",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass when enum is set",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "enum": [
            -9007199254740991,
            9007199254740991
          ]
        },
        "valid": true
      },
      {
        "description": "Should fail when enum values do not match declared type",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "enum": [
            "not-a-number",
            true
          ]
        },
        "valid": false
      },
      {
        "description": "Should fail when enum is not set",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer"
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=integer with minimum",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass when minimum is set",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "valid": true
      },
      {
        "description": "Should fail when minimum is not set",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "maximum": 0
        },
        "valid": false
      },
      {
        "description": "Should fail when minimum is < Number.MIN_SAFE_INTEGER",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "minimum": -9007199254740992,
          "maximum": 0
        },
        "valid": false
      },
      {
        "description": "Should fail when minimum is > Number.MAX_SAFE_INTEGER",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "minimum": 9007199254740992,
          "maximum": 0
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=integer with maximum",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass when maximum is set",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "valid": true
      },
      {
        "description": "Should fail when maximum is not set",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "minimum": 0
        },
        "valid": false
      },
      {
        "description": "Should fail when maximum is < Number.MIN_SAFE_INTEGER",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "maximum": -9007199254740992,
          "minimum": 0
        },
        "valid": false
      },
      {
        "description": "Should fail when maximum is > Number.MAX_SAFE_INTEGER",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "maximum": 9007199254740992,
          "minimum": 0
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=integer with exclusiveMinimum",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass when exclusiveMinimum is set",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "exclusiveMinimum": -9007199254740991,
          "exclusiveMaximum": 9007199254740991
        },
        "valid": true
      },
      {
        "description": "Should fail when minimum is not set",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "maximum": 0
        },
        "valid": false
      },
      {
        "description": "Should fail when exclusiveMinimum is < Number.MIN_SAFE_INTEGER",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "exclusiveMinimum": -9007199254740992,
          "exclusiveMaximum": 0
        },
        "valid": false
      },
      {
        "description": "Should fail when exclusiveMinimum is > Number.MAX_SAFE_INTEGER",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "exclusiveMinimum": 9007199254740992,
          "exclusiveMaximum": 0
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=integer with multipleOf",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass when multipleOf is positive",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "multipleOf": 5
        },
        "valid": true
      },
      {
        "description": "Should fail when multipleOf is zero",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "multipleOf": 0
        },
        "valid": false
      },
      {
        "description": "Should fail when multipleOf is negative",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "multipleOf": -1
        },
        "valid": false
      },
      {
        "description": "Should fail when multipleOf is used without type",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "multipleOf": 5
        },
        "valid": false
      },
      {
        "description": "Should fail when multipleOf exceeds Number.MAX_SAFE_INTEGER",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "multipleOf": 9007199254740992
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=integer with exclusiveMaximum",
    "schema": {
      "$ref": "urn:willfarrell:sast-json-schema:2020-12"
    },
    "tests": [
      {
        "description": "Should pass when exclusiveMaximum is set",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "exclusiveMinimum": -9007199254740991,
          "exclusiveMaximum": 9007199254740991
        },
        "valid": true
      },
      {
        "description": "Should fail when exclusiveMaximum is not set",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "valid": false
      },
      {
        "description": "Should fail when exclusiveMaximum is < Number.MIN_SAFE_INTEGER",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "exclusiveMaximum": -9007199254740992,
          "exclusiveMinimum": 0
        },
        "valid": false
      },
      {
        "description": "Should fail when exclusiveMaximum is > Number.MAX_SAFE_INTEGER",
        "data": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "test",
          "type": "integer",
          "exclusiveMaximum": 9007199254740992,
          "exclusiveMinimum": 0
        },
        "valid": false
      }
    ]
  }
]

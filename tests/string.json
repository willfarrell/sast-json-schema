[
  {
    "description": "type=[string,null]",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass",
        "data": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "test"
          ],
          "maxLength": 256
        },
        "valid": true
      },
      {
        "description": "Should fail",
        "data": {
          "type": [
            "string",
            "null"
          ]
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=string with const",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when const is set",
        "data": {
          "type": "string",
          "const": "fixed-value",
          "maxLength": 256
        },
        "valid": true
      },
      {
        "description": "Should fail when const is set without maxLength",
        "data": {
          "type": "string",
          "const": "fixed-value"
        },
        "valid": false
      },
      {
        "description": "Should fail when const type does not match declared type",
        "data": {
          "type": "string",
          "const": 42
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=string with enum",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when enum is set",
        "data": {
          "type": "string",
          "enum": [
            "test"
          ],
          "maxLength": 256
        },
        "valid": true
      },
      {
        "description": "Should fail when enum is set without maxLength",
        "data": {
          "type": "string",
          "enum": [
            "test"
          ]
        },
        "valid": false
      },
      {
        "description": "Should fail when enum is not set",
        "data": {
          "type": "string"
        },
        "valid": false
      },
      {
        "description": "Should fail when enum is not set",
        "data": {
          "type": [
            "string",
            "null"
          ]
        },
        "valid": false
      },
      {
        "description": "Should fail when enum values do not match declared type",
        "data": {
          "type": "string",
          "enum": [
            42,
            true
          ]
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=string with format",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when format is set to uuid",
        "data": {
          "type": "string",
          "format": "uuid",
          "maxLength": 36
        },
        "valid": true
      },
      {
        "description": "Should pass when format is set to date-time",
        "data": {
          "type": "string",
          "format": "date-time",
          "maxLength": 64
        },
        "valid": true
      },
      {
        "description": "Should pass when format is set to email",
        "data": {
          "type": "string",
          "format": "email",
          "maxLength": 254
        },
        "valid": true
      },
      {
        "description": "Should pass when format is set to uri",
        "data": {
          "type": "string",
          "format": "uri",
          "maxLength": 2048
        },
        "valid": true
      },
      {
        "description": "Should fail when format is not set",
        "data": {
          "type": "string"
        },
        "valid": false
      },
      {
        "description": "Should fail when format is set and maxLength is not set",
        "data": {
          "type": "string",
          "format": "uuid"
        },
        "valid": false
      },
      {
        "description": "Should pass when format is set to iso-date-time",
        "data": {
          "type": "string",
          "format": "iso-date-time",
          "maxLength": 64
        },
        "valid": true
      },
      {
        "description": "Should fail when format is unknown",
        "data": {
          "type": "string",
          "format": "nonsense",
          "maxLength": 100
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=string with pattern",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when pattern is set",
        "data": {
          "type": "string",
          "pattern": "^00000000-0000-0000-0000-000000000000$",
          "maxLength": 36
        },
        "valid": true
      },
      {
        "description": "Should fail when pattern is not set",
        "data": {
          "type": "string",
          "maxLength": 36
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern missing leading ^",
        "data": {
          "type": "string",
          "pattern": "00000000-0000-0000-0000-000000000000$",
          "maxLength": 36
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern missing trailing $",
        "data": {
          "type": "string",
          "pattern": "^00000000-0000-0000-0000-000000000000",
          "maxLength": 36
        },
        "valid": false
      },
      {
        "description": "Should pass when pattern contains `\\.` char",
        "data": {
          "type": "string",
          "pattern": "^00000000\\.0000-0000-0000-000000000000$",
          "maxLength": 36
        },
        "valid": true
      },
      {
        "description": "Should fail when pattern contains `.` char",
        "data": {
          "type": "string",
          "pattern": "^00000000.0000-0000-0000-000000000000$",
          "maxLength": 36
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains `\\S` char",
        "data": {
          "type": "string",
          "pattern": "^00000000\\S0000-0000-0000-000000000000$",
          "maxLength": 36
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains `\\W` char",
        "data": {
          "type": "string",
          "pattern": "^00000000\\W0000-0000-0000-000000000000$",
          "maxLength": 36
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains `\\D` char",
        "data": {
          "type": "string",
          "pattern": "^00000000\\D0000-0000-0000-000000000000$",
          "maxLength": 36
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains `\\C` char",
        "data": {
          "type": "string",
          "pattern": "^00000000\\C0000-0000-0000-000000000000$",
          "maxLength": 36
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains nested quantifier `(a+)+`",
        "data": {
          "type": "string",
          "pattern": "^(a+)+$",
          "maxLength": 36
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains nested quantifier `([a-z]+)*`",
        "data": {
          "type": "string",
          "pattern": "^([a-z]+)*$",
          "maxLength": 36
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains nested quantifier `(a+){2,}`",
        "data": {
          "type": "string",
          "pattern": "^(a+){2,}$",
          "maxLength": 36
        },
        "valid": false
      },
      {
        "description": "Should pass when pattern contains non-nested quantifier",
        "data": {
          "type": "string",
          "pattern": "^[a-z]+$",
          "maxLength": 36
        },
        "valid": true
      },
      {
        "description": "Should pass when pattern contains unicode character class escape",
        "data": {
          "type": "string",
          "pattern": "^[\\p{L}]*$",
          "maxLength": 256
        },
        "valid": true
      },
      {
        "description": "Should fail when pattern contains empty negated character class [^]",
        "data": {
          "type": "string",
          "pattern": "^[^]*$",
          "maxLength": 36
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains empty negated character class [^] with +",
        "data": {
          "type": "string",
          "pattern": "^[^]+$",
          "maxLength": 36
        },
        "valid": false
      },
      {
        "description": "Should fail when negated character class has content [^a] (broad denylist)",
        "data": {
          "type": "string",
          "pattern": "^[^a]+$",
          "maxLength": 36
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains \\P{L} (negated unicode property escape)",
        "data": {
          "type": "string",
          "pattern": "^\\P{L}+$",
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains \\P{N} in character class",
        "data": {
          "type": "string",
          "pattern": "^[\\P{N}]+$",
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains positive lookahead (?=...)",
        "data": {
          "type": "string",
          "pattern": "^(?=.*[A-Z])[a-zA-Z]+$",
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains positive lookbehind (?<=...)",
        "data": {
          "type": "string",
          "pattern": "^[a-z]+(?<=a)$",
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "Should pass when pattern contains non-capturing group (?:...)",
        "data": {
          "type": "string",
          "pattern": "^(?:abc|def)$",
          "maxLength": 100
        },
        "valid": true
      },
      {
        "description": "Should pass when pattern contains negative lookahead (?!...)",
        "data": {
          "type": "string",
          "pattern": "^(?!admin)[a-z]+$",
          "maxLength": 100
        },
        "valid": true
      },
      {
        "description": "Should pass when pattern contains negative lookbehind (?<!...)",
        "data": {
          "type": "string",
          "pattern": "^[a-z]+(?<!admin)$",
          "maxLength": 100
        },
        "valid": true
      },
      {
        "description": "Should fail when pattern contains bare alternation (breaks anchoring)",
        "data": {
          "type": "string",
          "pattern": "^abc|def|ghi$",
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern has alternation with quantifiers (breaks anchoring)",
        "data": {
          "type": "string",
          "pattern": "^[a-z]+|[0-9]+$",
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "Should pass when alternation is inside non-capturing group",
        "data": {
          "type": "string",
          "pattern": "^(?:abc|def|ghi)$",
          "maxLength": 100
        },
        "valid": true
      },
      {
        "description": "Should pass when alternation is inside nested groups",
        "data": {
          "type": "string",
          "pattern": "^(?:(?:abc|def)|(?:ghi|jkl))$",
          "maxLength": 100
        },
        "valid": true
      },
      {
        "description": "Should fail when alternation is at top level after group closes",
        "data": {
          "type": "string",
          "pattern": "^(?:a|b)|c$",
          "maxLength": 100
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=string with pattern length",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should fail when pattern exceeds maxLength (1024)",
        "data": {
          "type": "string",
          "pattern": "^$",
          "maxLength": 2000
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=string with maxLength",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "$todo": [
      "add in check for certain formats that have supreceeded",
      "reject use of non-escaped ., charset ranges should be used instead"
    ],
    "tests": [
      {
        "description": "Should pass when maxLength is set",
        "data": {
          "type": "string",
          "pattern": "^00000000-0000-0000-0000-000000000000$",
          "maxLength": 36
        },
        "valid": true
      },
      {
        "description": "Should fail when maxLength is not set",
        "data": {
          "type": "string",
          "pattern": "^00000000-0000-0000-0000-000000000000$"
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=string with minLength",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when minLength is a valid safeCount",
        "data": {
          "type": "string",
          "pattern": "^[\\p{L}]+$",
          "minLength": 1,
          "maxLength": 256
        },
        "valid": true
      },
      {
        "description": "Should fail when minLength is below 0",
        "data": {
          "type": "string",
          "pattern": "^[\\p{L}]+$",
          "minLength": -1,
          "maxLength": 256
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=string with combined constraints",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when format and pattern are both set",
        "data": {
          "type": "string",
          "format": "email",
          "pattern": "^[a-z]+@example\\.com$",
          "maxLength": 254
        },
        "valid": true
      },
      {
        "description": "Should pass when enum and format are both set",
        "data": {
          "type": "string",
          "enum": [
            "user@example.com"
          ],
          "format": "email",
          "maxLength": 254
        },
        "valid": true
      },
      {
        "description": "Should fail when none of const/enum/pattern/format is set",
        "data": {
          "type": "string",
          "maxLength": 100
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=string with contentMediaType",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when contentMediaType is application/json",
        "data": {
          "type": "string",
          "contentMediaType": "application/json",
          "format": "binary",
          "maxLength": 1024
        },
        "valid": true
      },
      {
        "description": "Should pass when contentMediaType is text/html",
        "data": {
          "type": "string",
          "contentMediaType": "text/html",
          "format": "binary",
          "maxLength": 1024
        },
        "valid": true
      },
      {
        "description": "Should pass when contentMediaType is a vendor type",
        "data": {
          "type": "string",
          "contentMediaType": "application/vnd.api+json",
          "format": "binary",
          "maxLength": 1024
        },
        "valid": true
      },
      {
        "description": "Should fail when contentMediaType has invalid top-level type",
        "data": {
          "type": "string",
          "contentMediaType": "foo/bar",
          "format": "binary",
          "maxLength": 1024
        },
        "valid": false
      },
      {
        "description": "Should fail when contentMediaType has no subtype",
        "data": {
          "type": "string",
          "contentMediaType": "application",
          "format": "binary",
          "maxLength": 1024
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=string with contentEncoding",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when contentEncoding is base64",
        "data": {
          "type": "string",
          "contentEncoding": "base64",
          "format": "binary",
          "maxLength": 1024
        },
        "valid": true
      },
      {
        "description": "Should pass when contentEncoding is base32",
        "data": {
          "type": "string",
          "contentEncoding": "base32",
          "format": "binary",
          "maxLength": 1024
        },
        "valid": true
      },
      {
        "description": "Should pass when contentEncoding is base16",
        "data": {
          "type": "string",
          "contentEncoding": "base16",
          "format": "binary",
          "maxLength": 1024
        },
        "valid": true
      },
      {
        "description": "Should pass when contentEncoding is quoted-printable",
        "data": {
          "type": "string",
          "contentEncoding": "quoted-printable",
          "format": "binary",
          "maxLength": 1024
        },
        "valid": true
      },
      {
        "description": "Should fail when contentEncoding is not in allowed list",
        "data": {
          "type": "string",
          "contentEncoding": "7bit",
          "format": "binary",
          "maxLength": 1024
        },
        "valid": false
      },
      {
        "description": "Should fail when contentEncoding is unknown",
        "data": {
          "type": "string",
          "contentEncoding": "nonsense",
          "format": "binary",
          "maxLength": 1024
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=string with backreference in pattern",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should fail when pattern contains backreference \\1",
        "data": {
          "type": "string",
          "pattern": "^(a)\\1+$",
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains backreference \\2",
        "data": {
          "type": "string",
          "pattern": "^(a)(b)\\2$",
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains named backreference \\k",
        "data": {
          "type": "string",
          "pattern": "^(?<name>a)\\k<name>$",
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains null byte escape \\0",
        "data": {
          "type": "string",
          "pattern": "^abc\\0def$",
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains \\B (non-word boundary)",
        "data": {
          "type": "string",
          "pattern": "^[a-z]+\\B[a-z]+$",
          "maxLength": 100
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=string with bare alternation between groups in pattern",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should fail when pattern has bare alternation between groups (breaks anchoring)",
        "data": {
          "type": "string",
          "pattern": "^(?!x)abc|(?!y)def$",
          "maxLength": 100
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=string with pattern escape sequences",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when pattern contains \\t (tab literal)",
        "data": {
          "type": "string",
          "pattern": "^[a-z\\t]+$",
          "maxLength": 100
        },
        "valid": true
      },
      {
        "description": "Should pass when pattern contains \\b (word boundary)",
        "data": {
          "type": "string",
          "pattern": "^\\b[a-z]+\\b$",
          "maxLength": 100
        },
        "valid": true
      },
      {
        "description": "Should pass when pattern contains \\x hex escape",
        "data": {
          "type": "string",
          "pattern": "^\\x41+$",
          "maxLength": 100
        },
        "valid": true
      },
      {
        "description": "Should pass when pattern contains \\u unicode escape",
        "data": {
          "type": "string",
          "pattern": "^\\u0041+$",
          "maxLength": 100
        },
        "valid": true
      },
      {
        "description": "Should pass when pattern contains \\d (digit class)",
        "data": {
          "type": "string",
          "pattern": "^\\d+$",
          "maxLength": 100
        },
        "valid": true
      },
      {
        "description": "Should pass when pattern contains \\w (word class)",
        "data": {
          "type": "string",
          "pattern": "^\\w+$",
          "maxLength": 100
        },
        "valid": true
      },
      {
        "description": "Should pass when pattern contains \\s (whitespace class)",
        "data": {
          "type": "string",
          "pattern": "^\\s+$",
          "maxLength": 100
        },
        "valid": true
      },
      {
        "description": "Should pass when pattern is empty anchors (matches empty string only)",
        "data": {
          "type": "string",
          "pattern": "^$",
          "maxLength": 0
        },
        "valid": true
      }
    ]
  },
  {
    "description": "type=string with pattern group edge cases",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should fail when pattern contains quantified non-capturing group (?:a+)+",
        "data": {
          "type": "string",
          "pattern": "^(?:a+)+$",
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains quantified non-capturing group (?:a+)*",
        "data": {
          "type": "string",
          "pattern": "^(?:a+)*$",
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains quantified non-capturing group (?:a+){2,}",
        "data": {
          "type": "string",
          "pattern": "^(?:a+){2,}$",
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "Should fail when non-capturing group has quantifier (?:abc)+",
        "data": {
          "type": "string",
          "pattern": "^(?:abc)+$",
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains named capture group with quantifier (?<name>a+)+",
        "data": {
          "type": "string",
          "pattern": "^(?<name>a+)+$",
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "Should pass when pattern contains named capture group without nested quantifier",
        "data": {
          "type": "string",
          "pattern": "^(?<name>abc)$",
          "maxLength": 100
        },
        "valid": true
      },
      {
        "description": "Should fail when pattern contains \\r (carriage return literal)",
        "data": {
          "type": "string",
          "pattern": "^abc\rdef$",
          "maxLength": 100
        },
        "valid": false
      },
      {
        "description": "Should fail when pattern contains \\n (newline literal)",
        "data": {
          "type": "string",
          "pattern": "^abc\ndef$",
          "maxLength": 100
        },
        "valid": false
      }
    ]
  },
  {
    "description": "type=string with enum item size limits",
    "schema": {
      "$ref": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/index.json"
    },
    "tests": [
      {
        "description": "Should pass when enum items are within size limits",
        "data": {
          "type": "string",
          "enum": [
            "short"
          ],

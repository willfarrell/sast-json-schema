{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://raw.githubusercontent.com/willfarrell/sast-json-schema/main/example.json",
	"$defs": {
		"allowed": { "type": "integer", "minimum": 0, "maximum": 1 },
		"allowedProperties": {
			"type": "object",
			"unevaluatedProperties": false,
			"properties": {
				"allowed": { "$ref": "#/$defs/allowed" },
				"if": { "$ref": "#/$defs/allowed" },
				"then": { "$ref": "#/$defs/allowed" },
				"else": { "$ref": "#/$defs/allowed" }
			},
			"maxProperties": 4,
			"required": []
		}
	},
	"allOf": [
		{
			"type": "object",
			"unevaluatedProperties": false,
			"properties": {
				"allowed": {
					"$ref": "#/$defs/allowed"
				},
				"if": {
					"$ref": "#/$defs/allowed"
				},
				"then": {
					"$ref": "#/$defs/allowed"
				},
				"else": {
					"$ref": "#/$defs/allowed"
				}
			},
			"maxProperties": 4,
			"required": []
		},
		{
			"type": "object",
			"unevaluatedProperties": false,
			"$ref": "#/$defs/allowedProperties",
			"properties": {},
			"maxProperties": 4,
			"required": [],
			"if": {
				"type": "object",
				"unevaluatedProperties": false,
				"$ref": "#/$defs/allowedProperties",
				"properties": {
					"if": {
						"type": "integer",
						"enum": [1]
					}
				},
				"maxProperties": 4,
				"required": ["if"]
			},
			"then": {
				"type": "object",
				"unevaluatedProperties": false,
				"$ref": "#/$defs/allowedProperties",
				"properties": {
					"then": {
						"type": "integer",
						"enum": [1]
					},
					"else": {
						"type": "integer",
						"enum": [0]
					}
				},
				"maxProperties": 4,
				"required": ["then", "else"]
			},
			"else": {
				"type": "object",
				"unevaluatedProperties": false,
				"$ref": "#/$defs/allowedProperties",
				"properties": {
					"else": {
						"type": "integer",
						"enum": [1]
					},
					"then": {
						"type": "integer",
						"enum": [0]
					}
				},
				"maxProperties": 4,
				"required": ["then", "else"]
			}
		}
	]
}
